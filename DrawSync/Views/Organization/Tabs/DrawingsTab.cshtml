@model DrawSync.Models.Organization

<div class="drawings-view">
    <div class="view-header">
        <div class="header-text">
            <h2>Drawings</h2>
            <p class="subtitle" id="drawingsCounter">Loading workspace statistics...</p>
        </div>
        <button id="newDrawingBtn" class="btn-new-drawing">
            <i class="bi bi-plus-lg"></i>
            New Drawing
        </button>
    </div>

    <div id="drawingsList" class="drawings-grid">
        <!-- Loading State -->
        <div class="loading-state">
            <div class="spinner-border text-indigo" role="status"></div>
            <p>Fetching your workspace drawings...</p>
        </div>
    </div>
</div>

<!-- Create Drawing Modal -->
<div id="createDrawingModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <h3>New Drawing</h3>
        <p class="modal-sub">Create a collaborative drawing in this workspace.</p>
        <form id="createDrawingForm">
            <div class="form-input-group">
                <label>Drawing Name</label>
                <input type="text" id="drawingName" placeholder="E.g. Sprint 14 brainstorm" required autofocus>
            </div>
            <div class="form-input-group">
                <label>Drawing Type</label>
                <div class="type-selector">
                    <label class="type-option">
                        <input type="radio" name="drawingType" value="whiteboard" checked>
                        <div class="type-card">
                            <i class="bi bi-easel"></i>
                            <span>Whiteboard</span>
                        </div>
                    </label>
                    <label class="type-option">
                        <input type="radio" name="drawingType" value="map">
                        <div class="type-card">
                            <i class="bi bi-map"></i>
                            <span>Map</span>
                        </div>
                    </label>
                </div>
            </div>
            <div class="modal-footer-btns">
                <button type="button" id="cancelCreateDrawing" class="btn-cancel">Cancel</button>
                <button type="submit" class="btn-submit">Create Drawing</button>
            </div>
        </form>
    </div>
</div>

<style>
    .drawings-view {
        padding: 8px 0;
    }

    .view-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .header-text h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--foreground);
        margin: 0 0 4px 0;
    }

    .subtitle {
        color: var(--muted-foreground);
        font-size: 0.9rem;
        margin: 0;
    }

    .btn-new-drawing {
        background: var(--primary);
        color: var(--primary-foreground) !important;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: var(--radius);
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s;
        box-shadow: var(--shadow-md);
        border: none;
        cursor: pointer;
    }

    .btn-new-drawing:hover {
        background: var(--primary-hover);
        transform: translateY(-1px);
    }

    .drawings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    .drawing-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

    .drawing-card:hover {
        border-color: var(--primary);
        box-shadow: var(--shadow-md);
        transform: translateY(-4px);
    }

    .card-icon {
        width: 48px;
        height: 48px;
        background: var(--secondary);
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.25rem;
        margin-bottom: 20px;
        transition: all 0.2s;
    }

    .drawing-card:hover .card-icon {
        background: hsl(from var(--primary) h s l / 0.12);
    }

    .drawing-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--foreground);
        margin: 0 0 8px 0;
    }

    .drawing-card p {
        color: var(--muted-foreground);
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0 0 20px 0;
        height: 40px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 16px;
        border-top: 1px solid var(--secondary);
    }

    .date-meta {
        font-size: 0.75rem;
        color: var(--muted-foreground);
        font-weight: 500;
    }

    .btn-delete {
        background: transparent;
        border: none;
        color: var(--destructive);
        font-size: 1.1rem;
        padding: 4px;
        border-radius: 6px;
        cursor: pointer;
        opacity: 0;
        transition: all 0.2s;
    }

    .drawing-card:hover .btn-delete {
        opacity: 1;
    }

    .btn-delete:hover {
        background: hsl(from var(--destructive) h s l / 0.1);
    }

    .loading-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 0;
        color: var(--muted-foreground);
    }

    /* Create Drawing Modal */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.45); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 2000; }
    .modal-card { background: var(--card); padding: 40px; border-radius: 24px; width: 90%; max-width: 440px; box-shadow: var(--shadow-xl); border: 1px solid var(--border); }
    .modal-card h3 { font-size: 1.5rem; font-weight: 800; color: var(--foreground); margin-bottom: 8px; }
    .modal-sub { color: var(--muted-foreground); margin-bottom: 28px; font-size: 0.95rem; }
    .form-input-group { margin-bottom: 22px; }
    .form-input-group label { display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 8px; }
    .form-input-group input { width: 100%; padding: 12px 16px; border: 1px solid var(--border); border-radius: 10px; font-size: 1rem; outline: none; background: var(--input-bg, var(--secondary)); color: var(--foreground); }
    .form-input-group input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px hsl(from var(--ring) h s l / 0.15); }
    .modal-footer-btns { display: flex; gap: 12px; margin-top: 28px; }
    .btn-cancel { flex: 1; padding: 14px; background: var(--secondary); border: none; border-radius: var(--radius); font-weight: 700; color: var(--foreground); cursor: pointer; transition: all 0.2s; }
    .btn-cancel:hover { filter: brightness(0.97); }
    .btn-submit { flex: 2; padding: 14px; background: var(--primary); border: none; border-radius: var(--radius); font-weight: 700; color: var(--primary-foreground); cursor: pointer; transition: all 0.2s; }
    .btn-submit:hover { background: var(--primary-hover); }

    .type-selector { display: flex; gap: 14px; }
    .type-option { flex: 1; cursor: pointer; }
    .type-option input { display: none; }
    .type-card { padding: 16px; border: 1px solid var(--border); border-radius: 12px; display: flex; flex-direction: column; align-items: center; gap: 8px; transition: all 0.2s; background: var(--secondary); }
    .type-card i { font-size: 1.4rem; color: var(--muted-foreground); }
    .type-card span { font-weight: 600; font-size: 0.85rem; color: var(--muted-foreground); }
    .type-option input:checked + .type-card { border-color: var(--primary); background: hsl(from var(--primary) h s l / 0.1); }
    .type-option input:checked + .type-card i, .type-option input:checked + .type-card span { color: var(--primary); }
</style>

<script>
    (function() {
        const orgId = '@Model.Id';
        const apiBase = `/api/organization/${orgId}`;

        async function loadDrawings() {
            try {
                const res = await fetch(`${apiBase}/drawings`);
                const drawings = await res.json();

                const list = document.getElementById('drawingsList');
                if (!drawings || drawings.length === 0) {
                    list.innerHTML = `
                        <div class="loading-state">
                            <i class="bi bi-canvas" style="font-size: 3rem; opacity: 0.2;"></i>
                            <p style="margin-top: 16px;">No drawings found in this workspace.</p>
                        </div>
                    `;
                } else {
                    list.innerHTML = drawings.map(d => {
                        const isMap = d.type === 'map';
                        return `
                            <div class="drawing-card" onclick="window.location.href='/organization/${orgId}/whiteboard/board/${d['$id']}'">
                                <div class="card-icon" style="background: ${isMap ? 'hsl(from var(--primary) h s l / 0.1)' : 'var(--secondary)'}; color: ${isMap ? '#3b82f6' : 'var(--primary)'}">
                                    <i class="bi ${isMap ? 'bi-map-fill' : 'bi-brush-fill'}"></i>
                                </div>
                                <h4>${d.name}</h4>
                                <p>${d.description || (isMap ? 'Georeferenced construction map.' : 'No description provided for this drawing.')}</p>
                                <div class="card-footer">
                                    <span class="date-meta">Created ${new Date(d['$createdAt']).toLocaleDateString()}</span>
                                    <button class="btn-delete" onclick="event.stopPropagation(); deleteDrawing('${d['$id']}')" title="Delete Drawing">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
                updateCounter();
            } catch (err) {
                console.error('Failed to load drawings:', err);
            }
        }

        async function updateCounter() {
            try {
                const res = await fetch(`${apiBase}/billing`);
                const data = await res.json();
                const count = document.querySelectorAll('#drawingsList .drawing-card').length;
                document.getElementById('drawingsCounter').textContent = `Workspace Usage: ${count} of ${data.limits.drawings} active drawings`;
            } catch (err) {
                console.error('Failed to get billing info:', err);
            }
        }

        window.deleteDrawing = async function(id) {
            if (confirm('Are you sure you want to delete this drawing? This action is permanent.')) {
                try {
                    const res = await fetch(`${apiBase}/drawings/${id}`, { method: 'DELETE' });
                    if (res.status === 403) {
                        let msg = 'Only organization admins can delete drawings.';
                        try { const d = await res.json(); if (d && d.error) msg = d.error; } catch (_) {}
                        alert(msg); return;
                    }
                    loadDrawings();
                } catch (err) {
                    alert('Failed to delete drawing');
                }
            }
        }

        // --- Create Drawing via the org API ---
        const createModal = document.getElementById('createDrawingModal');
        const createForm = document.getElementById('createDrawingForm');
        document.getElementById('newDrawingBtn').addEventListener('click', () => {
            createModal.style.display = 'flex';
            document.getElementById('drawingName').focus();
        });
        document.getElementById('cancelCreateDrawing').addEventListener('click', () => { createModal.style.display = 'none'; });
        createModal.addEventListener('click', (e) => { if (e.target === createModal) createModal.style.display = 'none'; });

        createForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const name = document.getElementById('drawingName').value.trim();
            const type = document.querySelector('input[name="drawingType"]:checked').value;
            if (!name) return;
            try {
                const res = await fetch(`${apiBase}/drawings`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, type })
                });
                if (res.ok) {
                    const drawing = await res.json();
                    window.location.href = `/organization/${orgId}/whiteboard/board/${drawing['$id'] || drawing.id}`;
                } else if (res.status === 403) {
                    let msg = 'You do not have permission to create drawings in this workspace.';
                    try { const d = await res.json(); if (d && d.error) msg = d.error; } catch (_) {}
                    alert(msg);
                } else {
                    let msg = 'Failed to create drawing';
                    try { const d = await res.json(); if (d && d.error) msg = d.error; } catch (_) {}
                    alert(msg);
                }
            } catch (err) {
                alert('Failed to create drawing');
            }
        });

        loadDrawings();
    })();
</script>
