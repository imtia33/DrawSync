@model DrawSync.Models.Organization

<div class="drawings-view">
    <div class="view-header">
        <div class="header-text">
            <h2>Drawings</h2>
            <p class="subtitle" id="drawingsCounter">Loading workspace statistics...</p>
        </div>
        <a href="/whiteboard" class="btn-new-drawing">
            <i class="bi bi-plus-lg"></i>
            New Drawing
        </a>
    </div>

    <div id="drawingsList" class="drawings-grid">
        <!-- Loading State -->
        <div class="loading-state">
            <div class="spinner-border text-indigo" role="status"></div>
            <p>Fetching your workspace drawings...</p>
        </div>
    </div>
</div>

<style>
    .drawings-view {
        padding: 8px 0;
    }

    .view-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .header-text h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--foreground);
        margin: 0 0 4px 0;
    }

    .subtitle {
        color: var(--muted-foreground);
        font-size: 0.9rem;
        margin: 0;
    }

    .btn-new-drawing {
        background: #0a0a0a;
        color: #ffffff !important;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: var(--radius);
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: opacity 0.2s;
        box-shadow: var(--shadow-md);
        border: none;
        cursor: pointer;
    }

    .btn-new-drawing:hover {
        opacity: 0.85;
    }

    .drawings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    .drawing-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

    .drawing-card:hover {
        border-color: var(--primary);
        box-shadow: var(--shadow-md);
        transform: translateY(-4px);
    }

    .card-icon {
        width: 48px;
        height: 48px;
        background: var(--secondary);
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.25rem;
        margin-bottom: 20px;
        transition: all 0.2s;
    }

    .drawing-card:hover .card-icon {
        background: hsl(from var(--primary) h s l / 0.12);
    }

    .drawing-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--foreground);
        margin: 0 0 8px 0;
    }

    .drawing-card p {
        color: var(--muted-foreground);
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0 0 20px 0;
        height: 40px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 16px;
        border-top: 1px solid var(--secondary);
    }

    .date-meta {
        font-size: 0.75rem;
        color: var(--muted-foreground);
        font-weight: 500;
    }

    .btn-delete {
        background: transparent;
        border: none;
        color: var(--destructive);
        font-size: 1.1rem;
        padding: 4px;
        border-radius: 6px;
        cursor: pointer;
        opacity: 0;
        transition: all 0.2s;
    }

    .drawing-card:hover .btn-delete {
        opacity: 1;
    }

    .btn-delete:hover {
        background: hsl(from var(--destructive) h s l / 0.1);
    }

    .loading-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 0;
        color: var(--muted-foreground);
    }
</style>

<script>
    (function() {
        const orgId = '@Model.Id';
        const apiBase = `/api/organization/${orgId}`;

        async function loadDrawings() {
            try {
                const res = await fetch(`${apiBase}/drawings`);
                const drawings = await res.json();

                const list = document.getElementById('drawingsList');
                if (!drawings || drawings.length === 0) {
                    list.innerHTML = `
                        <div class="loading-state">
                            <i class="bi bi-canvas" style="font-size: 3rem; opacity: 0.2;"></i>
                            <p style="margin-top: 16px;">No drawings found in this workspace.</p>
                        </div>
                    `;
                } else {
                    list.innerHTML = drawings.map(d => {
                        const isMap = d.type === 'map';
                        return `
                            <div class="drawing-card" onclick="window.location.href='/organization/${orgId}/whiteboard/board/${d['$id']}'">
                                <div class="card-icon" style="background: ${isMap ? 'hsl(from var(--primary) h s l / 0.1)' : 'var(--secondary)'}; color: ${isMap ? '#3b82f6' : 'var(--primary)'}">
                                    <i class="bi ${isMap ? 'bi-map-fill' : 'bi-brush-fill'}"></i>
                                </div>
                                <h4>${d.name}</h4>
                                <p>${d.description || (isMap ? 'Georeferenced construction map.' : 'No description provided for this drawing.')}</p>
                                <div class="card-footer">
                                    <span class="date-meta">Created ${new Date(d['$createdAt']).toLocaleDateString()}</span>
                                    <button class="btn-delete" onclick="event.stopPropagation(); deleteDrawing('${d['$id']}')" title="Delete Drawing">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
                updateCounter();
            } catch (err) {
                console.error('Failed to load drawings:', err);
            }
        }

        async function updateCounter() {
            try {
                const res = await fetch(`${apiBase}/billing`);
                const data = await res.json();
                const count = document.querySelectorAll('#drawingsList .drawing-card').length;
                document.getElementById('drawingsCounter').textContent = `Workspace Usage: ${count} of ${data.limits.drawings} active drawings`;
            } catch (err) {
                console.error('Failed to get billing info:', err);
            }
        }

        window.deleteDrawing = async function(id) {
            if (confirm('Are you sure you want to delete this drawing? This action is permanent.')) {
                try {
                    await fetch(`${apiBase}/drawings/${id}`, { method: 'DELETE' });
                    loadDrawings();
                } catch (err) {
                    alert('Failed to delete drawing');
                }
            }
        }

        loadDrawings();
    })();
</script>
