@model DrawSync.Models.Organization

<div class="drawings-view">
    <div class="view-header">
        <div class="header-text">
            <h2>Drawings</h2>
            <p class="subtitle" id="drawingsCounter">Loading workspace statistics...</p>
        </div>
        <a href="/whiteboard" class="btn-new-drawing">
            <i class="bi bi-plus-lg"></i>
            New Drawing
        </a>
    </div>

    <div id="drawingsList" class="drawings-grid">
        <!-- Loading State -->
        <div class="loading-state">
            <div class="spinner-border text-indigo" role="status"></div>
            <p>Fetching your workspace drawings...</p>
        </div>
    </div>
</div>

<style>
    .drawings-view {
        padding: 8px 0;
    }

    .view-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .header-text h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #111827;
        margin: 0 0 4px 0;
    }

    .subtitle {
        color: #6B7280;
        font-size: 0.9rem;
        margin: 0;
    }

    .btn-new-drawing {
        background: #4F46E5;
        color: white !important;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
    }

    .btn-new-drawing:hover {
        background: #4338CA;
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(79, 70, 229, 0.3);
    }

    .drawings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    .drawing-card {
        background: #FFFFFF;
        border: 1px solid #E5E7EB;
        border-radius: 16px;
        padding: 24px;
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

    .drawing-card:hover {
        border-color: #4F46E5;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.05);
        transform: translateY(-4px);
    }

    .card-icon {
        width: 48px;
        height: 48px;
        background: #F3F4F6;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4F46E5;
        font-size: 1.25rem;
        margin-bottom: 20px;
        transition: all 0.2s;
    }

    .drawing-card:hover .card-icon {
        background: #EEF2FF;
    }

    .drawing-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 8px 0;
    }

    .drawing-card p {
        color: #6B7280;
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0 0 20px 0;
        height: 40px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 16px;
        border-top: 1px solid #F3F4F6;
    }

    .date-meta {
        font-size: 0.75rem;
        color: #9CA3AF;
        font-weight: 500;
    }

    .btn-delete {
        background: transparent;
        border: none;
        color: #EF4444;
        font-size: 1.1rem;
        padding: 4px;
        border-radius: 6px;
        cursor: pointer;
        opacity: 0;
        transition: all 0.2s;
    }

    .drawing-card:hover .btn-delete {
        opacity: 1;
    }

    .btn-delete:hover {
        background: #FEF2F2;
    }

    .loading-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 0;
        color: #6B7280;
    }

    .text-indigo { color: #4F46E5 !important; }
</style>

<script>
    (function() {
        const orgId = '@Model.Id';
        const apiBase = `/api/organization/${orgId}`;

        async function loadDrawings() {
            try {
                const res = await fetch(`${apiBase}/drawings`);
                const drawings = await res.json();

                const list = document.getElementById('drawingsList');
                if (!drawings || drawings.length === 0) {
                    list.innerHTML = `
                        <div class="loading-state">
                            <i class="bi bi-canvas" style="font-size: 3rem; opacity: 0.2;"></i>
                            <p style="margin-top: 16px;">No drawings found in this workspace.</p>
                        </div>
                    `;
                } else {
                    list.innerHTML = drawings.map(d => `
                        <div class="drawing-card" onclick="window.location.href='/whiteboard/board/${d['$id']}'">
                            <div class="card-icon"><i class="bi bi-brush"></i></div>
                            <h4>${d.name}</h4>
                            <p>${d.description || 'No description provided for this drawing.'}</p>
                            <div class="card-footer">
                                <span class="date-meta">Created ${new Date(d['$createdAt']).toLocaleDateString()}</span>
                                <button class="btn-delete" onclick="event.stopPropagation(); deleteDrawing('${d['$id']}')" title="Delete Drawing">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    `).join('');
                }
                updateCounter();
            } catch (err) {
                console.error('Failed to load drawings:', err);
            }
        }

        async function updateCounter() {
            try {
                const res = await fetch(`${apiBase}/billing`);
                const data = await res.json();
                const count = document.querySelectorAll('#drawingsList .drawing-card').length;
                document.getElementById('drawingsCounter').textContent = `Workspace Usage: ${count} of ${data.limits.drawings} active drawings`;
            } catch (err) {
                console.error('Failed to get billing info:', err);
            }
        }

        window.deleteDrawing = async function(id) {
            if (confirm('Are you sure you want to delete this drawing? This action is permanent.')) {
                try {
                    await fetch(`${apiBase}/drawings/${id}`, { method: 'DELETE' });
                    loadDrawings();
                } catch (err) {
                    alert('Failed to delete drawing');
                }
            }
        }

        loadDrawings();
    })();
</script>
