@model DrawSync.Models.Organization

<div class="billing-section">
    <h2>Billing & Plan</h2>

    <div style="background: #f5f5f5; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
            <div>
                <h3 style="margin: 0 0 10px 0;">Current Plan</h3>
                <p style="margin: 0; font-size: 18px; font-weight: 600;">@Model.Plan.ToUpper()</p>
                <p style="color: #666; margin: 5px 0 0 0; font-size: 14px;">@GetPlanDescription(Model.Plan)</p>
            </div>
            @if (Model.Plan == "free")
            {
                <button id="upgradeBtn" class="btn-primary-custom" style="padding: 12px 24px;">Upgrade to Pro</button>
            }
            else
            {
                <span style="color: #4caf50; font-weight: 600;">✓ Pro Plan Active</span>
            }
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px;">
            <h3 style="margin-top: 0;">Free Plan</h3>
            <ul style="margin: 15px 0; padding-left: 20px; font-size: 14px;">
                <li><strong>1 Drawing</strong></li>
                <li><strong>3 Team Members</strong></li>
                <li>Basic collaboration</li>
                <li>Community support</li>
            </ul>
            @if (Model.Plan == "free")
            {
                <span style="color: #2196F3; font-weight: 600;">Your current plan</span>
            }
        </div>

        <div style="border: 2px solid #4caf50; border-radius: 8px; padding: 20px; background: #f0f8f4;">
            <h3 style="margin-top: 0; color: #4caf50;">Pro Plan</h3>
            <ul style="margin: 15px 0; padding-left: 20px; font-size: 14px;">
                <li><strong>5 Drawings</strong></li>
                <li><strong>15 Team Members</strong></li>
                <li>Advanced collaboration</li>
                <li>Priority support</li>
            </ul>
            @if (Model.Plan == "pro")
            {
                <span style="color: #4caf50; font-weight: 600;">✓ Your current plan</span>
            }
            else
            {
                <button id="upgradeBtn2" class="btn-primary-custom" style="padding: 10px 20px; background: #4caf50;">Upgrade Now</button>
            }
        </div>
    </div>

    <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px; background: #f9f9f9;">
        <h3>Usage Details</h3>
        <p style="color: #666; margin-bottom: 15px;">Your current organization usage:</p>
        <div id="usageDetails" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
            <div style="background: white; padding: 15px; border-radius: 6px; border-left: 4px solid #2196F3;">
                <p style="margin: 0; color: #666; font-size: 12px;">DRAWINGS</p>
                <p id="drawingsUsage" style="margin: 5px 0 0 0; font-size: 18px; font-weight: 600;">--</p>
            </div>
            <div style="background: white; padding: 15px; border-radius: 6px; border-left: 4px solid #FF9800;">
                <p style="margin: 0; color: #666; font-size: 12px;">TEAM MEMBERS</p>
                <p id="membersUsage" style="margin: 5px 0 0 0; font-size: 18px; font-weight: 600;">--</p>
            </div>
            <div style="background: white; padding: 15px; border-radius: 6px; border-left: 4px solid #9C27B0;">
                <p style="margin: 0; color: #666; font-size: 12px;">RENEWS</p>
                <p id="renewDate" style="margin: 5px 0 0 0; font-size: 14px; font-weight: 600;">--</p>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetPlanDescription(string plan) {
        return plan.ToLower() == "free" 
            ? "Basic plan with 1 drawing slot and 3 team member limit"
            : "Professional plan with 5 drawings and 15 team members";
    }
}

@section Scripts {
    <script>
        const orgId = '@Model.Id';
        const apiBase = `/api/organization/${orgId}`;

        async function upgradeToProClick() {
            if (confirm('Upgrade to Pro plan? This will unlock 5 drawings and 15 team member slots.')) {
                try {
                    const res = await fetch(`${apiBase}/billing/upgrade`, { method: 'POST' });
                    const data = await res.json();
                    if (res.ok) {
                        alert(data.message || 'Successfully upgraded to Pro!');
                        location.reload();
                    } else {
                        alert('Error: ' + (data.error || 'Upgrade failed'));
                    }
                } catch (err) {
                    alert('Upgrade failed: ' + err.message);
                }
            }
        }

        const upgradeBtn = document.getElementById('upgradeBtn');
        if (upgradeBtn) {
            upgradeBtn.addEventListener('click', upgradeToProClick);
        }

        const upgradeBtn2 = document.getElementById('upgradeBtn2');
        if (upgradeBtn2) {
            upgradeBtn2.addEventListener('click', upgradeToProClick);
        }

        async function loadUsage() {
            try {
                const res = await fetch(`${apiBase}/usage`);
                const usage = await res.json();
                document.getElementById('drawingsUsage').textContent = `${usage.drawingsCount}`;
                document.getElementById('membersUsage').textContent = `${usage.collaborators}`;
                const renewDate = new Date(usage.renewDate).toLocaleDateString();
                document.getElementById('renewDate').textContent = renewDate;
            } catch (err) {
                console.error('Failed to load usage:', err);
            }
        }

        loadUsage();
    </script>
}
