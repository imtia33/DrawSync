@model DrawSync.Models.Organization
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<div class="tab-view-container">
    <div class="view-header">
        <div class="header-text">
            <h2>Team Members</h2>
            <p class="subtitle" id="membersCounter">Loading workspace members...<span id="onlineCount" class="online-count" style="display:none"></span></p>
            <p id="adminHint" class="subtitle" style="display:none; color: var(--muted-foreground); font-size: 0.8rem; margin-top: 6px;">
                <i class="bi bi-shield-lock"></i> You have admin rights — you can invite and remove members.
            </p>
        </div>
        <button id="inviteMemberBtn" class="btn-new-drawing" style="display:none;">
            <i class="bi bi-person-plus"></i> Invite Member
        </button>
    </div>
    <div class="card-surface">
        <div id="membersList" class="table-responsive">
            <div class="loading-state">
                <div class="spinner-border text-indigo" role="status"></div>
                <p>Retrieving member list...</p>
            </div>
        </div>
    </div>
</div>

<div id="inviteModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <h3>Invite Team Member</h3>
        <p class="modal-sub">Add a new collaborator to your organization workspace.</p>
        <form id="inviteForm">
            <div class="form-input-group">
                <label>Email Address</label>
                <input type="email" id="inviteEmail" placeholder="colleague@example.com" required>
            </div>
            <div class="form-input-group">
                <label>Access Role</label>
                <select id="inviteRole">
                    <option value="member">Member (View & Draw)</option>
                    <option value="editor">Editor (Full Access)</option>
                    <option value="admin">Admin (Manage Billing)</option>
                </select>
            </div>
            <div class="modal-footer-btns">
                <button type="button" id="cancelInviteBtn" class="btn-cancel">Cancel</button>
                <button type="submit" class="btn-submit">Send Invitation</button>
            </div>
        </form>
    </div>
</div>

<style>
    .tab-view-container { padding: 8px 0; }
    .card-surface { background: var(--card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .table-responsive { width: 100%; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { background: var(--secondary); padding: 16px 24px; text-align: left; font-size: 0.75rem; font-weight: 700; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); }
    .data-table td { padding: 20px 24px; font-size: 0.9rem; color: var(--foreground); border-bottom: 1px solid var(--secondary); }
    .data-table tr:last-child td { border-bottom: none; }
    .role-badge { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; text-transform: capitalize; }
    .role-admin { background: hsl(from var(--primary) h s l / 0.12); color: var(--primary); }
    .role-editor { background: hsl(350 40% 90%); color: hsl(350 60% 40%); }
    .role-member { background: var(--secondary); color: var(--foreground); }
    .btn-remove { background: transparent; border: none; color: var(--destructive); font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; padding: 6px 12px; border-radius: 6px; }
    .btn-remove:hover { background: hsl(from var(--destructive) h s l / 0.1); }
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 2000; }
    .modal-card { background: var(--card); padding: 40px; border-radius: 24px; width: 90%; max-width: 440px; box-shadow: var(--shadow-xl); }
    .modal-card h3 { font-size: 1.5rem; font-weight: 800; color: var(--foreground); margin-bottom: 8px; }
    .modal-sub { color: var(--muted-foreground); margin-bottom: 32px; font-size: 0.95rem; }
    .form-input-group { margin-bottom: 24px; }
    .form-input-group label { display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 8px; }
    .form-input-group input, .form-input-group select { width: 100%; padding: 12px 16px; border: 1px solid var(--border); border-radius: 10px; font-size: 1rem; outline: none; background: var(--input-bg); color: var(--foreground); }
    .form-input-group input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px hsl(from var(--ring) h s l / 0.15); }
    .modal-footer-btns { display: flex; gap: 12px; margin-top: 32px; }
    .btn-cancel { flex: 1; padding: 14px; background: var(--secondary); border: none; border-radius: var(--radius); font-weight: 700; color: var(--foreground); cursor: pointer; transition: all 0.2s; }
    .btn-cancel:hover { filter: brightness(0.97); }
    .btn-submit { flex: 2; padding: 14px; background: var(--primary); border: none; border-radius: var(--radius); font-weight: 700; color: var(--primary-foreground); cursor: pointer; transition: all 0.2s; }
    .btn-submit:hover { background: var(--primary-hover); }
    .status-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 6px; vertical-align: middle; }
    .status-online { background: #10b981; box-shadow: 0 0 6px rgba(16,185,129,0.5); }
    .status-offline { background: #6b7280; opacity: 0.5; }
    .online-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; font-weight: 600; padding: 3px 8px; border-radius: 100px; }
    .online-badge.online { background: rgba(16,185,129,0.12); color: #10b981; }
    .online-badge.offline { background: var(--secondary); color: var(--muted-foreground); }
    .online-count { font-size: 0.85rem; color: #10b981; font-weight: 600; margin-left: 8px; }
</style>

<script>
(function() {
    const orgId = '@Model.Id';
    const apiBase = `/api/organization/${orgId}`;
    
    const appwriteEndpoint = '@Configuration["Appwrite:Endpoint"]';
    const appwriteProject = '@Configuration["Appwrite:Project"]';
    const currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
    const currentUserName = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(User.Identity?.Name ?? "Unknown"))';
    
    let appwriteJwt = '@ViewBag.AppwriteJwt';
    let heartbeatInterval = null;

    // Helper to refresh JWT token if expired
    async function refreshJwt() {
        try {
            const res = await fetch(`${apiBase}/jwt`);
            if (res.ok) {
                const data = await res.json();
                appwriteJwt = data.jwt;
                return true;
            }
        } catch (err) {
            console.error('Failed to refresh Appwrite JWT:', err);
        }
        return false;
    }

    // --- Presence Heartbeat directly to Appwrite ---
    async function sendHeartbeat() {
        if (!appwriteJwt) {
            await refreshJwt();
        }
        if (!appwriteJwt) return;

        const presenceId = `${orgId}_${currentUserId}`;
        const url = `${appwriteEndpoint}/presences/${presenceId}`;
        
        const payload = {
            userId: currentUserId,
            status: "online",
            permissions: [
                `read("team:${orgId}")`
            ],
            expiresAt: new Date(Date.now() + 120000).toISOString(),
            metadata: {
                userName: currentUserName,
                organizationId: orgId
            }
        };

        try {
            let res = await fetch(url, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Appwrite-Project': appwriteProject,
                    'X-Appwrite-JWT': appwriteJwt
                },
                body: JSON.stringify(payload)
            });

            if (res.status === 401) {
                console.log('JWT expired, refreshing...');
                const refreshed = await refreshJwt();
                if (refreshed) {
                    res = await fetch(url, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Appwrite-Project': appwriteProject,
                            'X-Appwrite-JWT': appwriteJwt
                        },
                        body: JSON.stringify(payload)
                    });
                }
            }
        } catch (err) {
            console.warn('Presence heartbeat failed:', err);
        }
    }

    // --- Fetch Active Presences directly from Appwrite ---
    async function fetchOnlinePresences() {
        if (!appwriteJwt) {
            await refreshJwt();
        }
        if (!appwriteJwt) return new Set();

        const url = `${appwriteEndpoint}/presences?queries[]=equal("status", "online")`;
        try {
            let res = await fetch(url, {
                method: 'GET',
                headers: {
                    'X-Appwrite-Project': appwriteProject,
                    'X-Appwrite-JWT': appwriteJwt
                }
            });

            if (res.status === 401) {
                const refreshed = await refreshJwt();
                if (refreshed) {
                    res = await fetch(url, {
                        method: 'GET',
                        headers: {
                            'X-Appwrite-Project': appwriteProject,
                            'X-Appwrite-JWT': appwriteJwt
                        }
                    });
                }
            }

            if (res.ok) {
                const data = await res.json();
                const activeIds = new Set();
                const list = data.presences || [];
                for (const p of list) {
                    if (p.id.startsWith(`${orgId}_`)) {
                        activeIds.add(p.userId);
                    }
                }
                return activeIds;
            }
        } catch (err) {
            console.warn('Failed to fetch online presences from Appwrite:', err);
        }
        return new Set();
    }

    // Send initial heartbeat and repeat every 30s
    sendHeartbeat();
    heartbeatInterval = setInterval(sendHeartbeat, 30000);
    // Re-send heartbeat when tab regains focus
    document.addEventListener('visibilitychange', () => { if (!document.hidden) sendHeartbeat(); });

    // --- Invite Modal ---
    document.getElementById('inviteMemberBtn').addEventListener('click', () => { document.getElementById('inviteModal').style.display = 'flex'; });
    document.getElementById('cancelInviteBtn').addEventListener('click', () => { document.getElementById('inviteModal').style.display = 'none'; });
    document.getElementById('inviteForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('inviteEmail').value;
        const role = document.getElementById('inviteRole').value;
        try {
            const res = await fetch(`${apiBase}/members/invite`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, role }) });
            if (res.ok) { document.getElementById('inviteForm').reset(); document.getElementById('inviteModal').style.display = 'none'; loadMembers(); }
            else { const data = await res.json(); alert('Error: ' + (data.error || 'Failed to invite member')); }
        } catch (err) { alert('Failed to invite member'); }
    });

    // --- Load Members ---
    async function loadMembers() {
        try {
            const res = await fetch(`${apiBase}/members`);
            const data = await res.json();
            const members = data.memberships || [];
            // Server tells us whether the current user may manage members.
            const isAdmin = data.isCurrentMemberAdmin === true;

            // Toggle the Invite button + admin hint visibility based on role.
            const inviteBtn = document.getElementById('inviteMemberBtn');
            const adminHint = document.getElementById('adminHint');
            if (isAdmin) {
                inviteBtn.style.display = 'flex';
                adminHint.style.display = 'block';
            } else {
                inviteBtn.style.display = 'none';
                adminHint.style.display = 'none';
            }

            const list = document.getElementById('membersList');
            if (!members || members.length === 0) {
                list.innerHTML = '<div class="loading-state"><p>No members found.</p></div>';
            } else {
                const onlineUserIds = await fetchOnlinePresences();
                const onlineTotal = members.filter(m => onlineUserIds.has(m.userId)).length;
                const onlineEl = document.getElementById('onlineCount');
                if (onlineTotal > 0) {
                    onlineEl.textContent = `\u2022 ${onlineTotal} online`;
                    onlineEl.style.display = 'inline';
                } else {
                    onlineEl.style.display = 'none';
                }
                let rows = members.map(m => {
                    const displayName = m.userName || m.userEmail || 'Unknown';
                    const avatarName = encodeURIComponent(displayName);
                    const role = (m.roles && m.roles[0]) || 'member';
                    const isOnline = onlineUserIds.has(m.userId);
                    const statusClass = isOnline ? 'online' : 'offline';
                    const statusText = isOnline ? 'Online' : 'Offline';
                    const createdDate = m.createdAt ? new Date(m.createdAt).toLocaleDateString() : '—';
                    // Admins see the Remove button (and never for their own membership).
                    const canRemove = isAdmin && m.userId !== currentUserId;
                    const actionCell = canRemove
                        ? `<button onclick="removeMember('${m.id}')" class="btn-remove">Remove</button>`
                        : `<span style="color: var(--muted-foreground); font-size: 0.8rem;">${m.userId === currentUserId ? 'You' : '—'}</span>`;
                    return `<tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:12px">
                                <div style="position:relative;display:inline-block">
                                    <img src="https://ui-avatars.com/api/?name=${avatarName}&background=6B2020&color=fff" style="width:36px;height:36px;border-radius:50%">
                                    <span class="status-dot status-${statusClass}" style="position:absolute;bottom:0;right:0;border:2px solid var(--card)"></span>
                                </div>
                                <div>
                                    <div style="font-weight:600">${displayName}</div>
                                    ${m.userEmail ? `<div style="font-size:0.75rem;color:var(--muted-foreground)">${m.userEmail}</div>` : ''}
                                </div>
                            </div>
                        </td>
                        <td><span class="role-badge role-${role}">${role}</span></td>
                        <td><span class="online-badge ${statusClass}"><span class="status-dot status-${statusClass}"></span>${statusText}</span></td>
                        <td class="subtitle" style="font-size:0.8rem">${createdDate}</td>
                        <td>${actionCell}</td>
                    </tr>`;
                }).join('');
                list.innerHTML = `<table class="data-table"><thead><tr><th>Member</th><th>Role</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead><tbody>${rows}</tbody></table>`;
            }
            updateCounter(members.length);
        } catch (err) { console.error('Failed to load members:', err); }
    }

    async function updateCounter(count) {
        try {
            const res = await fetch(`${apiBase}/billing`);
            const data = await res.json();
            const counterEl = document.getElementById('membersCounter');
            const base = `Organization Workspace: ${count} of ${data.limits.members} active members`;
            // Preserve the online count span
            const onlineSpan = counterEl.querySelector('#onlineCount');
            counterEl.childNodes[0].textContent = base;
            const btn = document.getElementById('inviteMemberBtn');
            if (count >= data.limits.members) { btn.disabled = true; btn.style.opacity = '0.5'; btn.title = 'Member limit reached'; }
        } catch (err) { console.error(err); }
    }

    window.removeMember = async function(id) {
        if (confirm('Are you sure you want to remove this member?')) {
            try {
                const res = await fetch(`${apiBase}/members/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadMembers();
                } else if (res.status === 403) {
                    let msg = 'Only organization admins can remove members.';
                    try { const d = await res.json(); if (d && d.error) msg = d.error; } catch (_) {}
                    alert(msg);
                } else {
                    let msg = 'Failed to remove member';
                    try { const d = await res.json(); if (d && d.error) msg = d.error; } catch (_) {}
                    alert(msg);
                }
            } catch (err) { alert('Failed to remove member'); }
        }
    }

    loadMembers();
    // Refresh members list every 30s to pick up presence changes
    setInterval(loadMembers, 30000);
})();
</script>
