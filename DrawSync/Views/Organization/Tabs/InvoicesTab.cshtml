@model DrawSync.Models.Organization

<div class="invoices-section">
    <h2>Invoices</h2>

    <div id="invoicesList" style="margin-bottom: 20px;">
        <p style="color: #999;">Loading invoices...</p>
    </div>
</div>

@section Scripts {
    <script>
        const orgId = '@Model.Id';
        const apiBase = `/api/organization/${orgId}`;

        async function loadInvoices() {
            try {
                const res = await fetch(`${apiBase}/invoices`);
                const invoices = await res.json();

                const list = document.getElementById('invoicesList');
                if (!invoices || invoices.length === 0) {
                    list.innerHTML = '<p style="color: #999;">No invoices yet.</p>';
                    return;
                }

                list.innerHTML = `
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 2px solid #e0e0e0;">
                                <th style="text-align: left; padding: 10px;">Period</th>
                                <th style="text-align: left; padding: 10px;">Amount</th>
                                <th style="text-align: left; padding: 10px;">Status</th>
                                <th style="text-align: left; padding: 10px;">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${invoices.map(inv => `
                                <tr style="border-bottom: 1px solid #e0e0e0;">
                                    <td style="padding: 10px;">${inv.period}</td>
                                    <td style="padding: 10px;">$${inv.amount.toFixed(2)} ${inv.currency}</td>
                                    <td style="padding: 10px;">
                                        <span style="padding: 4px 8px; border-radius: 4px; background: ${getStatusColor(inv.status)}; color: white; font-size: 12px;">
                                            ${inv.status.toUpperCase()}
                                        </span>
                                    </td>
                                    <td style="padding: 10px;">${new Date(inv['$createdAt']).toLocaleDateString()}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                `;
            } catch (err) {
                console.error('Failed to load invoices:', err);
            }
        }

        function getStatusColor(status) {
            switch (status) {
                case 'paid': return '#4caf50';
                case 'pending': return '#ff9800';
                case 'failed': return '#f44336';
                default: return '#999';
            }
        }

        loadInvoices();
    </script>
}
