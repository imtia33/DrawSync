@model DrawSync.Models.Organization

<div class="tab-view-container">
    <div class="view-header">
        <div class="header-text">
            <h2>Payment History</h2>
            <p class="subtitle">Review your past invoices and current billing status.</p>
        </div>
    </div>

    <div class="card-surface">
        <div id="invoicesList" class="table-responsive">
            <div class="loading-state">
                <div class="spinner-border text-indigo" role="status"></div>
                <p>Fetching transaction records...</p>
            </div>
        </div>
    </div>
    
    <div class="billing-support-footer">
        <p><i class="bi bi-question-circle"></i> Have questions about a charge? <a href="#">Contact Billing Support</a></p>
    </div>
</div>

<style>
    .status-pill { padding: 4px 12px; border-radius: 100px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
    .status-paid { background: #DCFCE7; color: #166534; }
    .status-pending { background: #FEF3C7; color: #92400E; }
    .status-failed { background: hsl(from var(--destructive) h s l / 0.12); color: var(--destructive); }
    .amount-text { font-weight: 700; color: var(--foreground); }
    .currency-tag { font-size: 0.75rem; color: var(--muted-foreground); margin-left: 4px; font-weight: 500; }
    .btn-download-invoice { background: var(--primary); border: 1px solid var(--primary); color: var(--primary-foreground); padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px; }
    .btn-download-invoice:hover { background: var(--primary-hover); }
    .billing-support-footer { margin-top: 24px; text-align: center; color: var(--muted-foreground); font-size: 0.85rem; }
    .billing-support-footer a { color: var(--primary); text-decoration: none; font-weight: 600; }
    .billing-support-footer a:hover { text-decoration: underline; }
</style>

<script>
(function() {
    const orgId = '@Model.Id';
    const apiBase = `/api/organization/${orgId}`;
    async function loadInvoices() {
        try {
            const res = await fetch(`${apiBase}/invoices`);
            const invoices = await res.json();
            const list = document.getElementById('invoicesList');
            if (!invoices || invoices.length === 0) {
                list.innerHTML = `<div class="loading-state"><i class="bi bi-receipt" style="font-size: 3rem; opacity: 0.2;"></i><p style="margin-top: 16px;">No invoices found yet. When you upgrade or renew, they'll appear here.</p></div>`;
                return;
            }
            let rows = invoices.map(inv => `<tr><td><span style="font-weight:600;color:var(--foreground)">${inv.period}</span></td><td><span class="amount-text">$${inv.amount.toFixed(2)}</span><span class="currency-tag">${inv.currency}</span></td><td><span class="status-pill status-${inv.status}">${inv.status}</span></td><td class="subtitle" style="font-size:0.8rem">${new Date(inv['$createdAt']).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td><td style="text-align:right"><button class="btn-download-invoice"><i class="bi bi-file-earmark-arrow-down"></i> PDF</button></td></tr>`).join('');
            list.innerHTML = `<table class="data-table"><thead><tr><th>Invoice Period</th><th>Amount</th><th>Status</th><th>Date</th><th></th></tr></thead><tbody>${rows}</tbody></table>`;
        } catch (err) { console.error(err); }
    }
    loadInvoices();
})();
</script>
