@model DrawSync.Models.Organization

<div class="tab-view-container">
    <div class="view-header">
        <div class="header-text">
            <h2>Workspace Settings</h2>
            <p class="subtitle">Manage organization preferences and security.</p>
        </div>
    </div>

    <div class="settings-grid">
        <div class="card-surface settings-form-card">
            <form id="settingsForm">
                <div class="form-input-group">
                    <label>Workspace Name</label>
                    <input type="text" id="orgName" value="@Model.Name" placeholder="e.g. Acme Design Team" required>
                    <p class="input-hint">This name will be visible to all members and on exported drawings.</p>
                </div>
                <div class="form-input-group">
                    <label>Organization Unique ID</label>
                    <div class="id-wrapper">
                        <input type="text" value="@Model.Id" disabled>
                        <i class="bi bi-lock-fill lock-icon"></i>
                    </div>
                    <p class="input-hint">Immutable system identifier for your organization.</p>
                </div>
                <div class="form-input-group">
                    <label>Workspace Created</label>
                    <input type="text" value="@(DateTime.TryParse(Model.CreatedAt, out var dt) ? dt.ToString("MMMM dd, yyyy") : Model.CreatedAt)" disabled>
                </div>
                <div class="settings-actions">
                    <button type="submit" class="btn-save-settings">Save Workspace Changes</button>
                </div>
            </form>
        </div>

        <div class="card-surface danger-zone-card">
            <div class="danger-header">
                <i class="bi bi-exclamation-octagon"></i>
                <h3>Danger Zone</h3>
            </div>
            <p class="danger-desc">Deleting this organization will permanently remove all associated drawings, member permissions, and billing history. This action is irreversible.</p>
            <div class="danger-footer">
                <button type="button" id="deleteOrgBtn" class="btn-delete-org">
                    <i class="bi bi-trash"></i>
                    Delete Organization
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .settings-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 24px; align-items: start; }
    .settings-form-card { padding: 40px; }
    .settings-form-card form { max-width: 500px; }
    .input-hint { font-size: 0.75rem; color: var(--muted-foreground); margin-top: 6px; }
    .id-wrapper { position: relative; }
    .id-wrapper input { background: var(--secondary) !important; color: var(--muted-foreground) !important; border-style: dashed !important; cursor: not-allowed; }
    .lock-icon { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--muted-foreground); opacity: 0.5; }
    .btn-save-settings { background: var(--primary); color: var(--primary-foreground); border: none; border-radius: var(--radius); padding: 14px 28px; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: var(--shadow-md); }
    .btn-save-settings:hover { background: var(--primary-hover); }
    .danger-zone-card { padding: 32px; border: 1px solid hsl(from var(--destructive) h s l / 0.2); background: hsl(from var(--destructive) h s l / 0.05); }
    .danger-header { display: flex; align-items: center; gap: 10px; color: var(--destructive); margin-bottom: 12px; }
    .danger-header h3 { font-size: 1.1rem; font-weight: 800; color: var(--destructive); margin: 0; }
    .danger-desc { font-size: 0.9rem; color: var(--destructive); opacity: 0.8; margin-bottom: 24px; line-height: 1.5; }
    .btn-delete-org { width: 100%; background: var(--card); color: var(--destructive); border: 1px solid hsl(from var(--destructive) h s l / 0.3); border-radius: var(--radius); padding: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .btn-delete-org:hover { background: var(--destructive); color: var(--destructive-foreground); border-color: var(--destructive); box-shadow: var(--shadow-lg); }
    @@media (max-width: 992px) { .settings-grid { grid-template-columns: 1fr; } }
</style>

<script>
(function() {
    const orgId = '@Model.Id';
    const apiBase = `/api/organization/${orgId}`;
    document.getElementById('settingsForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.getElementById('orgName').value;
        try {
            const res = await fetch(`${apiBase}/settings`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name }) });
            if (res.ok) { alert('Organization preferences updated.'); location.reload(); }
        } catch (err) { alert('Failed to update settings'); }
    });
    document.getElementById('deleteOrgBtn').addEventListener('click', () => {
        if (confirm('CRITICAL ACTION: This will permanently purge your entire organization. Are you absolutely certain?')) { deleteOrganization(); }
    });
    async function deleteOrganization() {
        try {
            const res = await fetch(`${apiBase}`, { method: 'DELETE' });
            if (res.ok) { alert('Workspace deleted. Redirecting...'); window.location.href = '/Organization'; }
        } catch (err) { alert('Deletion failed'); }
    }
})();
</script>
