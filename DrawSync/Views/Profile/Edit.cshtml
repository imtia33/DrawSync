@model DrawSync.Models.ViewModels.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg" style="border-radius: 20px;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Edit Profile</h2>
                        <p class="text-muted">Update your account information</p>
                    </div>

                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control" placeholder="Full Name" style="border-radius: 10px;" />
                            <label asp-for="Name"></label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 text-muted opacity-25">
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-primary"><i class="bi bi-key-fill me-1"></i> Change Password</label>
                            <p class="text-muted small mb-3">Leave blank if you don't want to change it.</p>
                            
                            <div class="form-floating mb-3">
                                <input asp-for="CurrentPassword" class="form-control" placeholder="Current Password" style="border-radius: 10px;" />
                                <label asp-for="CurrentPassword"></label>
                                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="NewPassword" class="form-control" placeholder="New Password" style="border-radius: 10px;" />
                                <label asp-for="NewPassword"></label>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password" style="border-radius: 10px;" />
                                <label asp-for="ConfirmPassword"></label>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-3 fw-bold rounded-pill shadow-sm">
                                Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-light py-3 fw-bold rounded-pill">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="alert alert-warning mt-4 small border-0 shadow-sm" style="border-radius: 15px;">
                <i class="bi bi-info-circle-fill me-2"></i> Note: Role changes are only permitted via terminal for security.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
