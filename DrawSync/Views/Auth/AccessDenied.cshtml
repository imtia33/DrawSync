@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-1 text-danger"><i class="bi bi-exclamation-triangle"></i></h1>
            <h1 class="text-danger">@ViewData["Title"]</h1>
            <p class="lead">You do not have permission to access this resource.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Return Home</a>
        </div>
    </div>
</div>
