@{
    ViewData["Title"] = "Access Denied";
}

<div class="blob-1 floating-blob"></div>
<div class="blob-2 floating-blob"></div>

<div class="auth-container">
    <div class="auth-card verification-card" style="max-width: 480px;">
        <div class="verification-icon-wrapper" style="background: hsl(from var(--destructive) h s l / 0.12); color: var(--destructive);">
            <i class="bi bi-shield-lock-fill" style="font-size: 2rem;"></i>
        </div>
        <h1 class="auth-title" style="font-size: 1.75rem;">Access Denied</h1>
        <p class="auth-subtitle" style="margin-bottom: 2rem;">
            You don't have permission to access this resource. If you believe this is a mistake, ask a
            workspace admin to invite you, or return to a workspace you belong to.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Home" asp-action="Index" class="btn-outline-custom" style="padding: 0.75rem 1.75rem; font-size: 0.9rem;">
                <i class="bi bi-house me-2"></i> Home
            </a>
            <a asp-controller="Organization" asp-action="Index" class="btn-primary-custom" style="padding: 0.75rem 1.75rem; font-size: 0.9rem;">
                <i class="bi bi-building me-2"></i> My Workspaces
            </a>
        </div>
    </div>
</div>
