@model DrawSync.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Welcome Back";
}

<div class="blob-1 floating-blob"></div>
<div class="blob-2 floating-blob"></div>

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">DrawSync</h1>
        <p class="auth-subtitle">Enter your details to access your account</p>

        <form asp-action="Login" method="post" id="loginForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @if (TempData["LoginError"] != null)
            {
                <div class="alert alert-danger" style="margin-bottom: 20px; font-size: 0.9rem; word-break: break-all;">
                    @TempData["LoginError"]
                </div>
            }
            @if (TempData["LoginSuccess"] != null)
            {
                <div class="alert alert-success" style="margin-bottom: 20px; font-size: 0.9rem; word-break: break-all; background-color: hsl(from var(--primary) h s l / 0.1); border-color: hsl(from var(--primary) h s l / 0.2); color: var(--primary);">
                    @TempData["LoginSuccess"]
                </div>
            }
            @if (TempData["VerificationError"] != null)
            {
                <div class="alert alert-danger" style="margin-bottom: 20px; font-size: 0.9rem; word-break: break-all;">
                    @TempData["VerificationError"]
                </div>
            }
            
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control-custom" placeholder="name@example.com" autocomplete="email" />
                <span asp-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label asp-for="Password" class="form-label mb-0">Password</label>
                    <a asp-action="ForgotPassword" class="auth-link" style="font-size: 0.8rem;">Forgot password?</a>
                </div>
                <div class="password-wrapper">
                    <input asp-for="Password" type="password" class="form-control-custom" placeholder="••••••••" id="passwordInput" />
                    <span class="password-toggle" id="passwordToggle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </span>
                </div>
                <span asp-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-group d-flex align-items-center mb-4">
                <input asp-for="RememberMe" class="form-check-input me-2" />
                <label asp-for="RememberMe" class="form-label mb-0" style="cursor: pointer;">Remember me</label>
            </div>

            <button type="submit" class="btn-primary-custom w-100" id="submitBtn">
                <span>Sign In</span>
            </button>
            
            <div class="auth-divider">
                <span>or</span>
            </div>
            
            <a asp-action="ContinueWithGoogle" class="btn-google-custom" id="googleBtn">
                <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                </svg>
                <span>Continue with Google</span>
            </a>
        </form>

        <div class="auth-footer">
            <p>New here? <a asp-action="Register" class="auth-link">Create an account</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const passwordInput = document.getElementById('passwordInput');
            const passwordToggle = document.getElementById('passwordToggle');
            const submitBtn = document.getElementById('submitBtn');
            const loginForm = document.getElementById('loginForm');

            // Password Toggle Logic
            passwordToggle.addEventListener('click', () => {
                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';
                passwordToggle.innerHTML = isPassword 
                    ? '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>'
                    : '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
            });

            // Loading State on Submit
            loginForm.addEventListener('submit', (e) => {
                if ($(loginForm).valid()) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Signing in...';
                }
            });

            // Input Focus Effects
            document.querySelectorAll('.form-control-custom').forEach(input => {
                input.addEventListener('focus', () => {
                    input.parentElement.querySelector('.form-label').style.color = 'var(--primary)';
                });
                input.addEventListener('blur', () => {
                    input.parentElement.querySelector('.form-label').style.color = 'var(--muted-foreground)';
                });
            });
        });
    </script>
}
