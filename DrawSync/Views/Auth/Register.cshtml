@model DrawSync.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="blob-1 floating-blob"></div>
<div class="blob-2 floating-blob"></div>

<div class="auth-container">
    <div class="auth-card" style="max-width: 500px;">
        <h1 class="auth-title">Join DrawSync</h1>
        <p class="auth-subtitle">Start your creative journey today</p>

        <form asp-action="Register" method="post" id="registerForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="Name" class="form-label">Full Name</label>
                <input asp-for="Name" class="form-control-custom" placeholder="John Doe" />
                <span asp-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control-custom" placeholder="name@example.com" />
                <span asp-for="Email" class="field-validation-error"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control-custom password-field" placeholder="••••••••" />
                        <span asp-for="Password" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control-custom password-field" placeholder="••••••••" />
                        <span asp-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn-primary-custom" id="submitBtn">
                <span>Create Account</span>
            </button>
        </form>

        <div class="auth-footer">
            <p>Already have an account? <a asp-action="Login" class="auth-link">Sign in</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const submitBtn = document.getElementById('submitBtn');
            const registerForm = document.getElementById('registerForm');

            // Loading State on Submit
            registerForm.addEventListener('submit', (e) => {
                if ($(registerForm).valid()) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creating account...';
                }
            });

            // Input Focus Effects
            document.querySelectorAll('.form-control-custom').forEach(input => {
                input.addEventListener('focus', () => {
                    input.parentElement.querySelector('.form-label').style.color = 'var(--primary)';
                });
                input.addEventListener('blur', () => {
                    input.parentElement.querySelector('.form-label').style.color = 'var(--text-muted)';
                });
            });
        });
    </script>
}
