@{
    Layout = "_Layout";
    ViewData["Title"] = ViewBag.BoardName ?? "Drawing Board";
    var boardType = ViewBag.BoardType as string ?? "whiteboard";
}

<link rel="stylesheet" href="~/css/whiteboard.css" />
<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

@section Scripts {
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="~/js/storage.js"></script>
    <script src="~/js/whiteboard.js"></script>
    <script src="~/js/map_geometry.js"></script>
    <script src="~/js/map_labels.js"></script>
    <script src="~/js/map_integration.js"></script>
    
    <script>
        document.body.classList.add('whiteboard-page');
        window.boardId = '@ViewBag.BoardId';
        const serverBoardType = '@boardType';

        document.addEventListener("DOMContentLoaded", async () => {
            let actualType = serverBoardType;
            
            // If local, we need to check IndexedDB
            if (actualType === 'local') {
                const board = await window.DrawStorage.getBoard(window.boardId);
                actualType = board ? board.type : 'whiteboard';
            }

            if (actualType === 'map') {
                document.body.classList.add('map-mode');
                initMapBoard("mapContainer", window.boardId);
            } else {
                document.body.classList.add('whiteboard-mode');
                if (window.Whiteboard) {
                    window.whiteboard = new Whiteboard("whiteboardCanvas", window.boardId);
                }
            }
        });
    </script>
}

<div class="app-container">
    <!-- Top Bar -->
    <header class="app-header">
        <div class="header-left">
            <a href="/whiteboard" class="back-btn" title="Back to Dashboard">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div class="divider"></div>
            <span id="displayBoardName" class="board-name">Loading...</span>
            <span id="saveStatus" class="save-status">Saved</span>
        </div>

        <!-- Whiteboard Toolbar (Visible only in whiteboard mode) -->
        <div class="toolbar-center whiteboard-only">
            <div class="tool-group">
                <button class="tool-btn active" data-tool="select" title="Selection (V)"><i class="bi bi-cursor-fill"></i></button>
                <button class="tool-btn" data-tool="pencil" title="Pencil (P)"><i class="bi bi-pencil-fill"></i></button>
                <button class="tool-btn" data-tool="neon" title="Neon Brush (N)"><i class="bi bi-magic"></i></button>
                <button class="tool-btn" data-tool="eraser" title="Eraser (E)"><i class="bi bi-eraser-fill"></i></button>
                <button class="tool-btn" data-tool="text" title="Text (T)"><i class="bi bi-type"></i></button>
                <button class="tool-btn" data-tool="pan" title="Pan (Space)"><i class="bi bi-hand-index-thumb"></i></button>
            </div>
            <div class="tool-divider"></div>
            <div class="tool-group">
                <button class="tool-btn" data-tool="line" title="Line (L)"><i class="bi bi-slash-lg"></i></button>
                <button class="tool-btn" data-tool="arrow" title="Arrow (A)"><i class="bi bi-arrow-up-right"></i></button>
                <button class="tool-btn" data-tool="rectangle" title="Rectangle (R)"><i class="bi bi-square"></i></button>
                <button class="tool-btn" data-tool="circle" title="Circle (O)"><i class="bi bi-circle"></i></button>
                <button class="tool-btn" data-tool="diamond" title="Diamond (D)"><i class="bi bi-diamond"></i></button>
            </div>
        </div>

        <!-- Map Toolbar (Visible only in map mode) -->
        <div class="toolbar-center map-only">
            <div class="tool-group">
                <button class="map-tool-btn active" data-map-tool="pan" title="Move Map"><i class="bi bi-arrows-move"></i></button>
                <button class="map-tool-btn" data-map-tool="edit" title="Select / Edit"><i class="bi bi-cursor-fill"></i></button>
                <button class="map-tool-btn" data-map-tool="marker" title="Add Marker"><i class="bi bi-geo-alt-fill"></i></button>
                <button class="map-tool-btn" data-map-tool="line" title="Draw Line"><i class="bi bi-slash-lg"></i></button>
                <button class="map-tool-btn" data-map-tool="arrow" title="Draw Arrow"><i class="bi bi-arrow-up-right"></i></button>
                <button class="map-tool-btn" data-map-tool="path" title="Measure Path"><i class="bi bi-rulers"></i></button>
                <button class="map-tool-btn" data-map-tool="polygon" title="Draw Area"><i class="bi bi-pentagon-fill"></i></button>
            </div>
            <div class="tool-divider"></div>
            <span class="map-info-text">GIS Construction Planner</span>
        </div>

        <div class="header-right">
            <button id="undoBtn" class="action-btn whiteboard-only" title="Undo (Ctrl+Z)"><i class="bi bi-arrow-counterclockwise"></i></button>
            <button id="redoBtn" class="action-btn whiteboard-only" title="Redo (Ctrl+Y)"><i class="bi bi-arrow-clockwise"></i></button>
            <div class="export-dropdown">
                <button id="exportBtn" class="action-btn primary" title="Export Options">
                    <i class="bi bi-download"></i>
                    Export
                </button>
                <div id="exportMenu" class="export-menu">
                    <button id="exportPng" class="export-item whiteboard-only">
                        <i class="bi bi-image"></i>
                        <span>Transparent PNG</span>
                    </button>
                    <button id="exportJpg" class="export-item whiteboard-only">
                        <i class="bi bi-file-earmark-image"></i>
                        <span>JPG with Background</span>
                    </button>
                    <button class="export-item map-only" onclick="window.print()">
                        <i class="bi bi-printer"></i>
                        <span>Print Map</span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div class="workspace-main">
        <!-- Sidebar (Whiteboard only) -->
        <aside class="app-sidebar whiteboard-only">
            <section class="sidebar-section">
                <label>Stroke & Fill</label>
                <div class="swatch-row">
                    <div class="swatch-container" id="strokeSwatchBtn">
                        <div class="swatch" id="strokeSwatch" style="background: #000000;"></div>
                        <span>Stroke</span>
                    </div>
                    <div class="swatch-container" id="fillSwatchBtn">
                        <div class="swatch is-transparent" id="fillSwatch" style="background: transparent;"></div>
                        <span>Fill</span>
                    </div>
                </div>
            </section>

            <section class="sidebar-section">
                <label>Brush Settings</label>
                <div class="setting-item">
                    <div class="setting-header">
                        <span>Size</span>
                        <span id="widthVal">2px</span>
                    </div>
                    <input type="range" id="strokeWidth" min="1" max="20" value="2">
                </div>
                <div class="setting-item">
                    <div class="setting-header">
                        <span>Opacity</span>
                        <span id="opacityVal">100%</span>
                    </div>
                    <input type="range" id="opacity" min="1" max="100" value="100">
                </div>
                <div class="setting-item neon-only-setting" style="display: none;">
                    <div class="setting-header">
                        <span>Glow Intensity</span>
                        <span id="glowVal">15px</span>
                    </div>
                    <input type="range" id="glowIntensity" min="5" max="40" value="15">
                </div>
            </section>

            <section class="sidebar-section">
                <label>Stroke Style</label>
                <div class="style-toggle-group" id="strokeStyle">
                    <button class="style-toggle active" data-value="solid"><i class="bi bi-dash-lg"></i></button>
                    <button class="style-toggle" data-value="dashed"><i class="bi bi-distribute-horizontal"></i></button>
                    <button class="style-toggle" data-value="dotted"><i class="bi bi-three-dots"></i></button>
                </div>
            </section>

            <section class="sidebar-section text-only-section" id="textSettingsSection" style="display: none;">
                <label>Text Settings</label>
                <div class="setting-item">
                    <div class="setting-header" style="margin-bottom: 6px;">
                        <span>Font Family</span>
                    </div>
                    <select id="fontFamily" class="style-select">
                        <option value="sans-serif">Sans-Serif</option>
                        <option value="serif">Serif</option>
                        <option value="monospace">Monospace</option>
                        <option value="Georgia">Georgia</option>
                        <option value="Impact">Impact</option>
                        <option value="Comic Sans MS">Comic Sans MS</option>
                    </select>
                </div>
                <div class="setting-item">
                    <div class="setting-header">
                        <span>Font Size</span>
                        <span id="fontSizeVal">24px</span>
                    </div>
                    <input type="range" id="fontSize" min="8" max="100" value="24">
                </div>
                <div class="style-toggle-group font-style-group">
                    <button class="style-toggle" id="btnBold" title="Bold" style="flex: 1;"><i class="bi bi-type-bold"></i></button>
                    <button class="style-toggle" id="btnItalic" title="Italic" style="flex: 1;"><i class="bi bi-type-italic"></i></button>
                    <button class="style-toggle" id="btnUnderline" title="Underline" style="flex: 1;"><i class="bi bi-type-underline"></i></button>
                </div>
            </section>

            <section class="sidebar-section">
                <label>Board Background</label>
                <div class="bg-presets">
                    <div class="bg-item active" data-bg="#f8f9fa" style="background: #f8f9fa;" title="Off White"></div>
                    <div class="bg-item" data-bg="#ffffff" style="background: #ffffff; border: 1px solid #eee;" title="Pure White"></div>
                    <div class="bg-item" data-bg="#1a1a1a" style="background: #1a1a1a;" title="Dark Mode"></div>
                    <div class="bg-item" data-bg="#2d3436" style="background: #2d3436;" title="Deep Gray"></div>
                    <div class="bg-item grid-item" data-bg="#f8f9fa" data-grid="true" title="Grid View">
                        <div class="mini-grid"></div>
                    </div>
                </div>
            </section>

            <div class="sidebar-footer">
                <button id="clearBtn" class="clear-canvas-btn"><i class="bi bi-trash"></i> Clear Board</button>
            </div>
        </aside>

        <!-- Main Area -->
        <main class="canvas-container" id="canvasParent">
            <canvas id="whiteboardCanvas" class="whiteboard-only"></canvas>
            <div id="mapContainer" class="map-only" style="width: 100%; height: 100%;"></div>
            
            <!-- Zoom Controls (Whiteboard only) -->
            <div class="zoom-overlay whiteboard-only">
                <button id="zoomOut" class="zoom-btn"><i class="bi bi-dash"></i></button>
                <span id="zoomLevel">100%</span>
                <button id="zoomIn" class="zoom-btn"><i class="bi bi-plus"></i></button>
            </div>
        </main>
    </div>

    <!-- Floating Color Picker (Hidden by default, Whiteboard Only) -->
    <div id="colorPickerPanel" class="popover-picker whiteboard-only" style="display: none;">
        <div class="picker-header">
            <span id="pickerTitle">Stroke Color</span>
            <div class="picker-header-actions">
                <button id="savePicker" title="Save & Apply"><i class="bi bi-check-lg"></i></button>
                <button id="closePicker" title="Close Panel"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>
        <div class="picker-body">
            <div class="wheel-box">
                <canvas id="hueWheel"></canvas>
                <canvas id="svSquare"></canvas>
                <div id="svCursor" class="picker-cursor"></div>
            </div>
            <div class="picker-footer">
                <div class="hex-box">
                    <label>HEX</label>
                    <input type="text" id="hexInput" value="#000000">
                </div>
                <button id="noFillBtn" class="no-fill-btn" title="No Fill / Transparent">
                    <i class="bi bi-x-circle"></i> None
                </button>
                <div id="colorPreview" class="preview-box"></div>
            </div>
        </div>
    </div>

    <!-- Adaptive Cursor (Whiteboard Only) -->
    <div id="customCursor" class="adaptive-cursor whiteboard-only"></div>

    <!-- Custom Alert Modal (Whiteboard Only) -->
    <div id="clearConfirmModal" class="custom-modal whiteboard-only">
        <div class="modal-card">
            <div class="modal-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <h2>Clear Whiteboard?</h2>
            <p>This will permanently erase all drawings on this board. This action cannot be undone.</p>
            <div class="modal-btns">
                <button id="cancelClear" class="cancel-btn">Cancel</button>
                <button id="confirmClear" class="confirm-btn">Clear Everything</button>
            </div>
        </div>
    </div>

    <!-- Custom Location Modal (Map Only) -->
    <div id="locationModal" class="custom-modal map-only" style="display: none;">
        <div class="modal-card">
            <div class="modal-icon location-icon"><i class="bi bi-geo-alt-fill"></i></div>
            <h2>Name this Location</h2>
            <p>Enter a label or title for your marker location.</p>
            <div class="form-input-group" style="width: 100%; margin-bottom: 24px; text-align: left;">
                <input type="text" id="locationNameInput" placeholder="E.g. Construction Area A" required autofocus style="width: 100%; padding: 12px; border: 1px solid var(--border-color); border-radius: 8px; font-size: 0.95rem; background: var(--input-bg, #ffffff); color: var(--text-main, #111827); outline: none;">
            </div>
            <div class="modal-btns">
                <button id="cancelLocation" class="cancel-btn">Cancel</button>
                <button id="confirmLocation" class="confirm-btn primary-btn">Save Location</button>
            </div>
        </div>
    </div>
</div>

<style>
    .app-header { z-index: 2000 !important; background: var(--bg-header) !important; }
    .app-container { z-index: 1500 !important; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; }
    
    /* Force hide default layout elements */
    header:not(.app-header) { display: none !important; }
    footer { display: none !important; }
    .main-content-container { padding-top: 0 !important; margin: 0 !important; }

    body:not(.whiteboard-mode) .whiteboard-only { display: none !important; }
    body:not(.map-mode) .map-only { display: none !important; }
    
    .map-mode .app-sidebar { display: none; }
    .map-mode .canvas-container { padding: 0 !important; }
    
    .map-tool-btn {
        background: transparent;
        border: none;
        color: var(--muted-foreground);
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    .map-tool-btn:hover { background: var(--secondary); color: var(--foreground); }
    .map-tool-btn.active { background: oklch(from var(--primary) l c h / 0.1); color: var(--primary); }
    
    .map-info-text {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--muted-foreground);
        text-transform: uppercase;
        letter-spacing: 1px;
        padding-left: 10px;
    }

    #mapContainer {
        background: #aad3df; /* Leaflet default bg */
        border-radius: 12px;
        overflow: hidden;
    }
</style>

