@{
    ViewData["Title"] = "My Whiteboards";
    var currentOrgId = ViewBag.OrgId as string;
}

<link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&display=swap" rel="stylesheet">

<div class="dashboard-wrapper">
    <!-- Navbar -->
    <nav class="dashboard-navbar">
        <div class="nav-container">
            <div class="nav-left">
                <span class="brand">DRAW<span class="brand-accent">SYNC</span></span>
                <div class="nav-links">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <a href="/Organization" class="active">Workspaces</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
            <div class="nav-right">
                <button id="wbThemeToggle" class="theme-toggle-btn" title="Toggle dark mode"><i class="bi bi-moon-stars-fill"></i></button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="user-profile">
                        <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=6B2020&color=fff" alt="User" class="avatar">
                        <span class="user-name">@User.Identity.Name</span>
                    </div>
                }
            </div>
        </div>
    </nav>

    <!-- Hero Header -->
    <header class="hero-header">
        <div class="hero-container">
            <h1>@(!string.IsNullOrEmpty(currentOrgId) ? "Workspace Drawings" : "Local Whiteboards")</h1>
            <p>@(string.IsNullOrEmpty(currentOrgId) ? "Your personal scratchpad for quick ideas." : "Secure collaborative boards for this organization.")</p>
        </div>
    </header>

    <!-- Main Content -->
    <main class="dashboard-main">
        <div class="main-container">
            <section class="action-toolbar">
                <div class="search-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text" id="boardSearch" placeholder="Search boards...">
                </div>
                <div class="sort-wrapper">
                    <select id="sortOrder">
                        <option value="updated">Last Modified</option>
                        <option value="created">Date Created</option>
                        <option value="name">Name</option>
                    </select>
                    <i class="bi bi-chevron-down select-icon"></i>
                </div>
                <button id="createBoardBtn" class="btn-new-board">
                    <i class="bi bi-plus-lg"></i>
                    New Board
                </button>
            </section>

            <section id="boardsGrid" class="boards-grid">
                <!-- Boards will be injected here -->
            </section>

            <div id="emptyState" class="empty-state" style="display: none;">
                <div class="empty-illustration">
                    <i class="bi bi-easel"></i>
                </div>
                <h3>No drawings found</h3>
                <p>Start a new brainstorm by creating your first board.</p>
                <button onclick="document.getElementById('createBoardBtn').click()" class="btn-new-board">
                    Create Board
                </button>
            </div>
        </div>
    </main>
</div>

<!-- Board Actions Dropdown -->
<div id="actionMenu" class="action-menu" style="display: none;">
    <button class="action-item delete" id="deleteActionBtn">
        <i class="bi bi-trash"></i>
        Delete
    </button>
</div>

<!-- Create Board Modal -->
<div id="createModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <h3>New Whiteboard</h3>
        <p class="modal-sub">Enter a name for your workspace board.</p>
        <form id="createBoardForm">
            <div class="form-input-group">
                <label for="boardName">Board Name</label>
                <input type="text" id="boardName" placeholder="E.g. Project brainstorm" required autofocus>
            </div>
            <div class="form-input-group" style="margin-top: 20px;">
                <label>Board Type</label>
                <div class="type-selector">
                    <label class="type-option">
                        <input type="radio" name="boardType" value="whiteboard" checked>
                        <div class="type-card">
                            <i class="bi bi-easel"></i>
                            <span>Whiteboard</span>
                        </div>
                    </label>
                    <label class="type-option">
                        <input type="radio" name="boardType" value="map">
                        <div class="type-card">
                            <i class="bi bi-map"></i>
                            <span>Map</span>
                        </div>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="closeModalBtn" class="btn-cancel">Cancel</button>
                <button type="submit" class="btn-submit">Create Board</button>
            </div>
        </form>
    </div>
</div>

<!-- Custom Delete Confirmation Modal -->
<div id="deleteConfirmModal" class="modal-overlay alert-modal" style="display: none;">
    <div class="modal-card confirmation-card">
        <div class="alert-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h3>Delete drawing?</h3>
        <p class="modal-sub">This will permanently remove "<span id="deleteTargetName"></span>" and all its strokes. This action cannot be undone.</p>
        <div class="modal-footer">
            <button type="button" id="cancelDeleteBtn" class="btn-cancel">Keep Drawing</button>
            <button type="button" id="confirmDeleteBtn" class="btn-submit btn-danger-custom">Yes, Delete</button>
        </div>
    </div>
</div>

<style>
    /* Global Overrides */
    body { background-color: var(--background) !important; }
    header:not(.hero-header):not(.dashboard-navbar) { display: none !important; }
    footer { display: none !important; }
    main[role="main"] { padding: 0 !important; max-width: none !important; }
    .container { max-width: none !important; padding: 0 !important; }

    .dashboard-wrapper {
        min-height: 100vh;
        font-family: var(--font-sans);
    }

    /* Navbar */
    .dashboard-navbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 70px;
        background: var(--card);
        border-bottom: 1px solid var(--border);
        z-index: 1000;
        display: flex;
        align-items: center;
    }

    .nav-container { width: 100%; max-width: 1280px; margin: 0 auto; padding: 0 24px; display: flex; justify-content: space-between; align-items: center; }
    .nav-left { display: flex; align-items: center; gap: 40px; }
    .brand { font-family: 'Syncopate', sans-serif; font-weight: 700; font-size: 1.1rem; letter-spacing: -1px; color: var(--foreground); }
    .brand-accent { color: var(--primary); }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a { text-decoration: none; color: var(--muted-foreground); font-weight: 500; font-size: 0.95rem; transition: all 0.2s; position: relative; }
    .nav-links a:hover { color: var(--foreground); }
    .nav-links a.active { color: var(--primary); font-weight: 600; }
    .nav-links a.active::after { content: ''; position: absolute; bottom: -24px; left: 0; width: 100%; height: 2px; background: var(--primary); }
    .nav-right { display: flex; align-items: center; gap: 16px; }
    .user-profile { display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; }
    .user-name { font-weight: 600; font-size: 0.95rem; color: var(--foreground); }

    /* Hero Header */
    .hero-header { background: var(--sidebar); padding: 120px 0 60px; text-align: left; }
    .hero-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
    .hero-header h1 { font-size: 3rem; font-weight: 800; color: var(--sidebar-foreground); margin-bottom: 12px; letter-spacing: -1px; }
    .hero-header p { font-size: 1.1rem; color: var(--muted-foreground); max-width: 600px; }

    /* Main Content */
    .dashboard-main { padding: 40px 0; }
    .main-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

    /* Toolbar */
    .action-toolbar { display: flex; gap: 16px; margin-bottom: 40px; align-items: center; }
    .search-wrapper { flex: 1; position: relative; }
    .search-wrapper i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--muted-foreground); }
    .search-wrapper input { width: 100%; padding: 14px 14px 14px 48px; border-radius: 10px; border: 1px solid var(--border); background: var(--card); color: var(--foreground); font-size: 0.95rem; outline: none; transition: all 0.2s; }
    .search-wrapper input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px oklch(from var(--ring) l c h / 0.15); }

    .sort-wrapper { position: relative; min-width: 180px; }
    .sort-wrapper select { width: 100%; padding: 14px 40px 14px 16px; background: var(--sidebar); color: var(--sidebar-foreground); border: none; border-radius: 10px; appearance: none; font-weight: 500; font-size: 0.9rem; cursor: pointer; }
    .select-icon { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--sidebar-foreground); pointer-events: none; }

    .btn-new-board { background: var(--primary); color: var(--primary-foreground); border: none; padding: 0 24px; height: 52px; border-radius: 10px; font-weight: 600; display: flex; align-items: center; gap: 10px; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
    .btn-new-board:hover { background: var(--primary-hover); transform: translateY(-2px); box-shadow: var(--shadow-lg); }

    /* Grid & Cards */
    .boards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px; }
    .board-card { background: var(--sidebar); border-radius: 16px; overflow: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; border: 1px solid var(--sidebar-border); position: relative; }
    .board-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-xl); border-color: var(--sidebar-accent); }
    .card-thumbnail { height: 160px; background: oklch(from var(--sidebar) calc(l - 0.05) c h); position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .preview-placeholder { width: 60%; height: 60%; border: 2px dashed var(--sidebar-border); border-radius: 8px; }
    .card-footer { padding: 20px; position: relative; }
    .card-footer h3 { color: var(--sidebar-foreground); font-size: 1.1rem; font-weight: 600; margin-bottom: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-meta { display: flex; flex-direction: column; gap: 6px; }
    .meta-item { display: flex; align-items: center; gap: 8px; color: var(--muted-foreground); font-size: 0.8rem; }
    .btn-kebab { position: absolute; top: 20px; right: 15px; background: transparent; border: none; color: var(--muted-foreground); cursor: pointer; font-size: 1.25rem; padding: 4px; border-radius: 6px; transition: all 0.2s; z-index: 10; }
    .btn-kebab:hover { background: var(--sidebar-accent); color: var(--sidebar-foreground); }

    /* Action Menu Dropdown */
    .action-menu { 
        position: absolute; 
        width: 120px; 
        background: var(--card); 
        border: 1px solid var(--border); 
        border-radius: 12px; 
        box-shadow: var(--shadow-lg); 
        z-index: 100; 
        overflow: hidden; 
        backdrop-filter: blur(12px); 
        animation: slideDownFade 0.2s ease-out;
    }
    .action-item { width: 100%; padding: 10px 14px; border: none; background: transparent; display: flex; align-items: center; gap: 10px; font-size: 0.8rem; font-weight: 600; color: var(--foreground); cursor: pointer; transition: all 0.2s; }
    .action-item:hover { background: var(--secondary); }
    .action-item.delete { color: var(--destructive); }
    .action-item.delete:hover { background: oklch(from var(--destructive) l c h / 0.1); }

    /* Modal Overlay & Card */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; z-index: 2000; animation: fadeIn 0.3s ease; }
    .modal-card { background: var(--card); width: 100%; max-width: 440px; padding: 40px; border-radius: 24px; box-shadow: var(--shadow-xl); border: 1px solid var(--border); animation: modalScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
    
    /* Confirmation Specific Styles */
    .confirmation-card { text-align: center; border-color: oklch(from var(--destructive) l c h / 0.3); }
    .alert-icon { width: 64px; height: 64px; background: oklch(from var(--destructive) l c h / 0.1); color: var(--destructive); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 24px; }
    .btn-danger-custom { background: var(--destructive) !important; color: var(--destructive-foreground) !important; }
    .btn-danger-custom:hover { background: oklch(from var(--destructive) calc(l - 0.05) c h) !important; }

    .modal-card h3 { font-weight: 800; font-size: 1.5rem; color: var(--foreground); margin-bottom: 8px; }
    .modal-sub { color: var(--muted-foreground); font-size: 0.95rem; margin-bottom: 32px; line-height: 1.5; }
    .form-input-group label { display: block; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 8px; }
    .form-input-group input { width: 100%; padding: 14px; border: 1px solid var(--border); border-radius: 10px; font-size: 1rem; outline: none; transition: border-color 0.2s; background: var(--input-bg); color: var(--foreground); }
    .form-input-group input:focus { border-color: var(--primary); }
    .modal-footer { display: flex; gap: 12px; margin-top: 32px; }
    .btn-cancel { flex: 1; padding: 14px; background: var(--secondary); border: none; border-radius: 10px; font-weight: 600; color: var(--foreground); cursor: pointer; transition: all 0.2s; }
    .btn-cancel:hover { background: oklch(from var(--secondary) calc(l - 0.02) c h); }
    .btn-submit { flex: 1.5; padding: 14px; background: var(--primary); border: none; border-radius: 10px; font-weight: 600; color: var(--primary-foreground); cursor: pointer; transition: all 0.2s; }
    .btn-submit:hover { background: var(--primary-hover); }

    /* Type Selector */
    .type-selector { display: flex; gap: 16px; margin-top: 8px; }
    .type-option { flex: 1; cursor: pointer; }
    .type-option input { display: none; }
    .type-card { 
        padding: 16px; 
        border: 1px solid var(--border); 
        border-radius: 12px; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        gap: 8px; 
        transition: all 0.2s;
        background: var(--sidebar);
    }
    .type-card i { font-size: 1.5rem; color: var(--muted-foreground); }
    .type-card span { font-weight: 600; font-size: 0.85rem; color: var(--muted-foreground); }
    .type-option input:checked + .type-card { 
        border-color: var(--primary); 
        background: oklch(from var(--primary) l c h / 0.1); 
    }
    .type-option input:checked + .type-card i { color: var(--primary); }
    .type-option input:checked + .type-card span { color: var(--primary); }

    /* Animations */
    @@keyframes slideDownFade {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes modalScale {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    /* State UI */
    .empty-state { text-align: center; padding: 100px 20px; color: var(--muted-foreground); }
    .empty-illustration { font-size: 80px; color: var(--muted-foreground); opacity: 0.3; margin-bottom: 24px; }
    .loading-state { grid-column: 1 / -1; text-align: center; padding: 100px 0; color: var(--muted-foreground); }

    /* Responsive */
    @@media (max-width: 768px) {
        .nav-links { display: none; }
        .hero-header h1 { font-size: 2.25rem; }
    }
</style>

@section Scripts {
    <script src="~/js/storage.js"></script>
    <script>
        const currentOrgId = '@currentOrgId';
        let allBoards = [];
        let activeBoardId = null;

        // Theme toggle
        (function() {
            const btn = document.getElementById('wbThemeToggle');
            if (!btn) return;
            const icon = btn.querySelector('i');
            function updateIcon() {
                const isDark = document.documentElement.classList.contains('dark');
                icon.className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
            }
            updateIcon();
            btn.addEventListener('click', () => {
                document.documentElement.classList.toggle('dark');
                const isDark = document.documentElement.classList.contains('dark');
                localStorage.setItem('drawsync-theme', isDark ? 'dark' : 'light');
                updateIcon();
            });
        })();

        async function loadBoards() {
            try { 
                allBoards = await window.DrawStorage.getBoards(currentOrgId || null); 
                renderBoards(); 
            }
            catch (err) { console.error("Failed to load boards:", err); }
        }

        function renderBoards() {
            const grid = document.getElementById('boardsGrid');
            const empty = document.getElementById('emptyState');
            const searchTerm = document.getElementById('boardSearch').value.toLowerCase();
            const sortOrder = document.getElementById('sortOrder').value;

            let filtered = allBoards.filter(b => b.name.toLowerCase().includes(searchTerm));
            filtered.sort((a, b) => {
                if (sortOrder === 'updated') return new Date(b.updatedAt) - new Date(a.updatedAt);
                if (sortOrder === 'created') return new Date(b.createdAt) - new Date(a.createdAt);
                if (sortOrder === 'name') return a.name.localeCompare(b.name);
                return 0;
            });

            if (filtered.length === 0 && searchTerm === '') {
                grid.style.display = 'none'; empty.style.display = 'block';
            } else {
                grid.style.display = 'grid'; empty.style.display = 'none';
                grid.innerHTML = filtered.map(b => {
                    const url = currentOrgId 
                        ? `/organization/${currentOrgId}/whiteboard/board/${b.id}`
                        : `/whiteboard/board/${b.id}`;
                    const isMap = b.type === 'map';
                    return `
                        <div class="board-card" onclick="window.location.href='${url}'" id="card-${b.id}">
                            <div class="card-thumbnail">
                                <div class="preview-placeholder">
                                    <i class="bi ${isMap ? 'bi-map' : 'bi-brush'}" style="font-size: 2rem; color: var(--muted-foreground); opacity: 0.5;"></i>
                                </div>
                            </div>
                            <div class="card-footer">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <i class="bi ${isMap ? 'bi-map-fill' : 'bi-brush-fill'}" style="color: ${isMap ? '#3b82f6' : 'var(--primary)'}; font-size: 0.9rem;"></i>
                                    <h3>${b.name}</h3>
                                </div>
                                <div class="card-meta">
                                    <div class="meta-item"><i class="bi bi-clock"></i> Updated ${new Date(b.updatedAt).toLocaleDateString()}</div>
                                    <div class="meta-item"><i class="bi bi-calendar"></i> Created ${new Date(b.createdAt).toLocaleDateString()}</div>
                                </div>
                                <button class="btn-kebab" onclick="event.stopPropagation(); showActions(event, '${b.id}', '${b.name.replace(/'/g, "\\'")}')">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                            </div>
                        </div>
                    `;
                }).join('');
            }
        }

        // Action Menu Logic
        window.showActions = function(e, boardId, boardName) {
            const menu = document.getElementById('actionMenu');
            activeBoardId = boardId;
            menu.dataset.boardName = boardName;
            
            // Toggle menu
            if (menu.style.display === 'flex' && menu.dataset.activeId === boardId) {
                hideMenu();
                return;
            }

            const rect = e.currentTarget.getBoundingClientRect();
            menu.style.display = 'flex';
            menu.style.flexDirection = 'column';
            menu.dataset.activeId = boardId;
            menu.style.top = `${rect.bottom + window.scrollY + 10}px`;
            menu.style.left = `${rect.right - 120 + window.scrollX}px`;
            menu.style.position = 'absolute';
            document.body.appendChild(menu);

            const outsideClick = (ev) => {
                if (!menu.contains(ev.target) && !e.currentTarget.contains(ev.target)) {
                    hideMenu();
                    document.removeEventListener('mousedown', outsideClick);
                }
            };
            document.addEventListener('mousedown', outsideClick);
        };

        function hideMenu() {
            const menu = document.getElementById('actionMenu');
            menu.style.display = 'none';
        }

        // Delete Confirmation Logic
        document.getElementById('deleteActionBtn').addEventListener('click', () => {
            const menu = document.getElementById('actionMenu');
            const boardName = menu.dataset.boardName;
            document.getElementById('deleteTargetName').textContent = boardName;
            document.getElementById('deleteConfirmModal').style.display = 'flex';
            hideMenu();
        });

        document.getElementById('cancelDeleteBtn').addEventListener('click', () => {
            document.getElementById('deleteConfirmModal').style.display = 'none';
        });

        document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
            if (!activeBoardId) return;
            await window.DrawStorage.deleteBoard(activeBoardId);
            document.getElementById('deleteConfirmModal').style.display = 'none';
            loadBoards();
        });

        async function createBoard(e) {
            e.preventDefault();
            const name = document.getElementById('boardName').value;
            const type = document.querySelector('input[name="boardType"]:checked').value;
            const board = await window.DrawStorage.createBoard(name, type);
            const url = currentOrgId 
                ? `/organization/${currentOrgId}/whiteboard/board/${board.id}`
                : `/whiteboard/board/${board.id}`;
            window.location.href = url;
        }

        document.getElementById('createBoardBtn').addEventListener('click', () => { document.getElementById('createModal').style.display = 'flex'; document.getElementById('boardName').focus(); });
        document.getElementById('closeModalBtn').addEventListener('click', () => { document.getElementById('createModal').style.display = 'none'; });
        document.getElementById('createBoardForm').addEventListener('submit', createBoard);
        document.getElementById('boardSearch').addEventListener('input', renderBoards);
        document.getElementById('sortOrder').addEventListener('change', renderBoards);

        loadBoards();
    </script>
}
