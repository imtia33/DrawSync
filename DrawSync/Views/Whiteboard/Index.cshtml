@{
    ViewData["Title"] = "My Whiteboards";
}

<link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&display=swap" rel="stylesheet">

<div class="dashboard-wrapper">
    <!-- Navbar -->
    <nav class="dashboard-navbar">
        <div class="nav-container">
            <div class="nav-left">
                <span class="brand">DRAW<span class="brand-accent">SYNC</span></span>
                <div class="nav-links">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-controller="Whiteboard" asp-action="Index" class="active">Whiteboard</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
            <div class="nav-right">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="user-profile">
                        <img src="https://ui-avatars.com/api/?name=Tareef&background=4F46E5&color=fff" alt="User" class="avatar">
                        <span class="user-name">Tareef</span>
                    </div>
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="btn-logout">Logout</button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <!-- Hero Header -->
    <header class="hero-header">
        <div class="hero-container">
            <h1>My Whiteboards</h1>
            <p>Manage your local drawing boards securely in your browser.</p>
        </div>
    </header>

    <!-- Main Content -->
    <main class="dashboard-main">
        <div class="main-container">
            <!-- Consolidated Action Toolbar -->
            <section class="action-toolbar">
                <div class="search-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text" id="boardSearch" placeholder="Search boards...">
                </div>
                <div class="sort-wrapper">
                    <select id="sortOrder">
                        <option value="updated">Last Modified</option>
                        <option value="created">Date Created</option>
                        <option value="name">Name</option>
                    </select>
                    <i class="bi bi-chevron-down select-icon"></i>
                </div>
                <button id="createBoardBtn" class="btn-new-board">
                    <i class="bi bi-plus-lg"></i>
                    New Board
                </button>
            </section>

            <!-- Whiteboard Grid -->
            <section id="boardsGrid" class="boards-grid">
                <!-- Boards will be injected here -->
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Fetching your creations...</p>
                </div>
            </section>

            <!-- Empty State -->
            <div id="emptyState" class="empty-state" style="display: none;">
                <div class="empty-illustration">
                    <i class="bi bi-canvas"></i>
                </div>
                <h3>No whiteboards yet</h3>
                <p>Create your first local whiteboard to start drawing!</p>
                <button onclick="document.getElementById('createBoardBtn').click()" class="btn-new-board">
                    Create Board
                </button>
            </div>
        </div>
    </main>
</div>

<!-- Create Board Modal -->
<div id="createModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <h3>New Whiteboard</h3>
        <p class="modal-sub">Enter a name for your workspace.</p>
        <form id="createBoardForm">
            <div class="form-input-group">
                <label for="boardName">Board Name</label>
                <input type="text" id="boardName" placeholder="E.g. Project brainstorm" required autofocus>
            </div>
            <div class="modal-footer">
                <button type="button" id="closeModalBtn" class="btn-cancel">Cancel</button>
                <button type="submit" class="btn-submit">Create Board</button>
            </div>
        </form>
    </div>
</div>

<style>
    /* Global Overrides */
    body { background-color: #F3F4F6 !important; }
    header:not(.hero-header):not(.dashboard-navbar) { display: none !important; }
    footer { display: none !important; }
    main[role="main"] { padding: 0 !important; max-width: none !important; }
    .container { max-width: none !important; padding: 0 !important; }

    /* Layout Variables */
    :root {
        --indigo: #4F46E5;
        --indigo-dark: #4338ca;
        --charcoal: #111827;
        --gray-muted: #6B7280;
        --card-dark: #1E1E1E;
        --border-soft: rgba(0,0,0,0.05);
        --radius-std: 12px;
        --shadow-elevated: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }

    .dashboard-wrapper {
        min-height: 100vh;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Navbar */
    .dashboard-navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: #FFFFFF;
        border-bottom: 1px solid var(--border-soft);
        z-index: 1000;
        display: flex;
        align-items: center;
    }

    .nav-container {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .nav-left { display: flex; align-items: center; gap: 40px; }
    
    .brand {
        font-family: 'Syncopate', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: -1px;
        color: var(--charcoal);
    }
    .brand-accent { color: var(--indigo); }

    .nav-links { display: flex; gap: 24px; }
    .nav-links a {
        text-decoration: none;
        color: var(--gray-muted);
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.2s;
        position: relative;
    }
    .nav-links a:hover { color: var(--charcoal); }
    .nav-links a.active { color: var(--indigo); font-weight: 600; }
    .nav-links a.active::after {
        content: '';
        position: absolute;
        bottom: -24px;
        left: 0;
        width: 100%;
        height: 2px;
        background: var(--indigo);
    }

    .nav-right { display: flex; align-items: center; gap: 20px; }

    .user-profile { display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; }
    .user-name { font-weight: 600; font-size: 0.95rem; color: var(--charcoal); }

    .btn-logout {
        background: transparent;
        border: 1px solid var(--gray-muted);
        color: var(--gray-muted);
        padding: 6px 16px;
        border-radius: 8px;
        font-weight: 500;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-logout:hover { background: #f3f4f6; color: var(--charcoal); border-color: var(--charcoal); }

    /* Hero Header */
    .hero-header {
        background: var(--charcoal);
        padding: 120px 0 60px;
        text-align: left;
    }

    .hero-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .hero-header h1 {
        font-size: 3rem;
        font-weight: 800;
        color: #FFFFFF;
        margin-bottom: 12px;
        letter-spacing: -1px;
    }

    .hero-header p {
        font-size: 1.1rem;
        color: var(--gray-muted);
        max-width: 600px;
    }

    /* Main Content */
    .dashboard-main { padding: 40px 0; }
    .main-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

    /* Toolbar */
    .action-toolbar {
        display: flex;
        gap: 16px;
        margin-bottom: 40px;
        align-items: center;
    }

    .search-wrapper {
        flex: 1;
        position: relative;
    }
    .search-wrapper i {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-muted);
    }
    .search-wrapper input {
        width: 100%;
        padding: 14px 14px 14px 48px;
        border-radius: 10px;
        border: 1px solid rgba(0,0,0,0.08);
        background: #FFFFFF;
        font-size: 0.95rem;
        outline: none;
        transition: all 0.2s;
    }
    .search-wrapper input:focus { border-color: var(--indigo); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }

    .sort-wrapper {
        position: relative;
        min-width: 180px;
    }
    .sort-wrapper select {
        width: 100%;
        padding: 14px 40px 14px 16px;
        background: var(--card-dark);
        color: #FFFFFF;
        border: none;
        border-radius: 10px;
        appearance: none;
        font-weight: 500;
        font-size: 0.9rem;
        cursor: pointer;
    }
    .select-icon {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #FFFFFF;
        pointer-events: none;
    }

    .btn-new-board {
        background: var(--indigo);
        color: white;
        border: none;
        padding: 0 24px;
        height: 52px;
        border-radius: 10px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }
    .btn-new-board:hover {
        background: var(--indigo-dark);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.4);
    }

    /* Grid & Cards */
    .boards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 32px;
    }

    .board-card {
        background: var(--card-dark);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .board-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 40px -10px rgba(0,0,0,0.3);
        border-color: rgba(255,255,255,0.1);
    }

    .card-thumbnail {
        height: 160px;
        background: #121212;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .preview-placeholder {
        width: 60%;
        height: 60%;
        border: 2px dashed rgba(255,255,255,0.1);
        border-radius: 8px;
    }

    .card-footer {
        padding: 20px;
        position: relative;
    }

    .card-footer h3 {
        color: #FFFFFF;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 12px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-meta { display: flex; flex-direction: column; gap: 6px; }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--gray-muted);
        font-size: 0.8rem;
    }
    .meta-item i { font-size: 0.9rem; }

    .btn-kebab {
        position: absolute;
        top: 20px;
        right: 15px;
        background: transparent;
        border: none;
        color: var(--gray-muted);
        cursor: pointer;
        font-size: 1.25rem;
        padding: 4px;
        border-radius: 6px;
        transition: all 0.2s;
    }
    .btn-kebab:hover { background: rgba(255,255,255,0.05); color: #FFFFFF; }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }

    .modal-card {
        background: #FFFFFF;
        width: 100%;
        max-width: 440px;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 30px 60px -12px rgba(0,0,0,0.3);
    }

    .modal-card h3 { font-weight: 800; font-size: 1.5rem; color: var(--charcoal); margin-bottom: 8px; }
    .modal-sub { color: var(--gray-muted); font-size: 0.95rem; margin-bottom: 32px; }

    .form-input-group label { display: block; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; color: var(--gray-muted); margin-bottom: 8px; }
    .form-input-group input {
        width: 100%;
        padding: 14px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
    }
    .form-input-group input:focus { border-color: var(--indigo); }

    .modal-footer { display: flex; gap: 12px; margin-top: 32px; }
    .btn-cancel { flex: 1; padding: 14px; background: #f3f4f6; border: none; border-radius: 12px; font-weight: 600; color: var(--charcoal); cursor: pointer; }
    .btn-submit { flex: 2; padding: 14px; background: var(--indigo); border: none; border-radius: 12px; font-weight: 600; color: #FFFFFF; cursor: pointer; }

    /* States */
    .empty-state { text-align: center; padding: 100px 20px; }
    .empty-illustration { font-size: 80px; color: #d1d5db; margin-bottom: 24px; }
    .loading-state { grid-column: 1 / -1; text-align: center; padding: 100px 0; }

    /* Responsive */
    @@media (max-width: 768px) {
        .nav-links { display: none; }
        .hero-header h1 { font-size: 2.25rem; }
        .action-toolbar { flex-direction: column; align-items: stretch; }
        .sort-wrapper { min-width: 0; }
    }
</style>

@section Scripts {
    <script src="~/js/storage.js"></script>
    <script>
        let allBoards = [];

        async function loadBoards() {
            try {
                allBoards = await window.DrawStorage.getBoards();
                renderBoards();
            } catch (err) {
                console.error("Failed to load boards:", err);
            }
        }

        function renderBoards() {
            const grid = document.getElementById('boardsGrid');
            const empty = document.getElementById('emptyState');
            const searchTerm = document.getElementById('boardSearch').value.toLowerCase();
            const sortOrder = document.getElementById('sortOrder').value;

            let filtered = allBoards.filter(b => b.name.toLowerCase().includes(searchTerm));

            filtered.sort((a, b) => {
                if (sortOrder === 'updated') return new Date(b.updatedAt) - new Date(a.updatedAt);
                if (sortOrder === 'created') return new Date(b.createdAt) - new Date(a.createdAt);
                if (sortOrder === 'name') return a.name.localeCompare(b.name);
                return 0;
            });

            if (filtered.length === 0 && searchTerm === '') {
                grid.style.display = 'none';
                empty.style.display = 'block';
            } else {
                grid.style.display = 'grid';
                empty.style.display = 'none';

                grid.innerHTML = filtered.map(b => `
                    <div class="board-card" onclick="window.location.href='/whiteboard/board/${b.id}'">
                        <div class="card-thumbnail">
                            <div class="preview-placeholder"></div>
                        </div>
                        <div class="card-footer">
                            <h3>${b.name}</h3>
                            <div class="card-meta">
                                <div class="meta-item"><i class="bi bi-clock"></i> Updated ${new Date(b.updatedAt).toLocaleDateString()}</div>
                                <div class="meta-item"><i class="bi bi-calendar"></i> Created ${new Date(b.createdAt).toLocaleDateString()}</div>
                            </div>
                            <button class="btn-kebab" onclick="event.stopPropagation(); showActions('${b.id}')">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                        </div>
                    </div>
                `).join('');
            }
        }

        async function createBoard(e) {
            e.preventDefault();
            const name = document.getElementById('boardName').value;
            const board = await window.DrawStorage.createBoard(name);
            window.location.href = `/whiteboard/board/${board.id}`;
        }

        // Listeners
        document.getElementById('createBoardBtn').addEventListener('click', () => {
            document.getElementById('createModal').style.display = 'flex';
            document.getElementById('boardName').focus();
        });

        document.getElementById('closeModalBtn').addEventListener('click', () => {
            document.getElementById('createModal').style.display = 'none';
        });

        document.getElementById('createBoardForm').addEventListener('submit', createBoard);
        document.getElementById('boardSearch').addEventListener('input', renderBoards);
        document.getElementById('sortOrder').addEventListener('change', renderBoards);

        loadBoards();
    </script>
}
