@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-page">
    <div class="privacy-container">
        <header class="privacy-header">
            <div class="privacy-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1>Privacy Policy</h1>
            <p class="privacy-updated">Last updated: @DateTime.UtcNow.ToString("MMMM yyyy")</p>
        </header>

        <div class="privacy-content">
            <section class="privacy-section">
                <h2><i class="bi bi-1-circle"></i> Information We Collect</h2>
                <p>
                    DrawSync collects the information you provide when registering an account &mdash;
                    your name, email address, and organization name &mdash; along with the drawings and
                    strokes you create on collaborative boards. We use Appwrite as our backend data
                    provider, which stores this data securely in the cloud.
                </p>
            </section>

            <section class="privacy-section">
                <h2><i class="bi bi-2-circle"></i> How We Use Your Information</h2>
                <ul>
                    <li>To authenticate you and manage your team workspaces.</li>
                    <li>To display your name and presence to teammates collaborating on the same board.</li>
                    <li>To enforce per-organization access control so only members of your team can view your drawings.</li>
                    <li>To provide product features such as realtime collaborative drawing.</li>
                </ul>
            </section>

            <section class="privacy-section">
                <h2><i class="bi bi-3-circle"></i> Data Sharing &amp; Access</h2>
                <p>
                    We do not sell your data. Drawings are scoped to your organization: only members of
                    the team a drawing belongs to can view or edit it. Organization admins can invite
                    and remove members within their workspace.
                </p>
            </section>

            <section class="privacy-section">
                <h2><i class="bi bi-4-circle"></i> Your Rights</h2>
                <p>
                    You may request export or deletion of your account data at any time by contacting
                    your workspace admin. Deleting your account removes your access to shared boards;
                    drawings you authored remain accessible to remaining team members.
                </p>
            </section>

            <section class="privacy-section">
                <h2><i class="bi bi-5-circle"></i> Contact</h2>
                <p>
                    For privacy questions or data requests, reach out to your organization administrator.
                </p>
            </section>
        </div>

        <div class="privacy-back">
            <a asp-controller="Home" asp-action="Index" class="btn-outline-custom">
                <i class="bi bi-arrow-left me-2"></i> Back to Home
            </a>
        </div>
    </div>
</div>

<style>
    .privacy-page {
        padding: 60px 20px 80px;
    }
    .privacy-container {
        max-width: 820px;
        margin: 0 auto;
    }
    .privacy-header {
        text-align: center;
        margin-bottom: 48px;
        animation: slideUp 0.6s ease-out;
    }
    .privacy-icon {
        width: 72px;
        height: 72px;
        margin: 0 auto 20px;
        border-radius: 20px;
        background: hsl(from var(--primary) h s l / 0.1);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }
    .privacy-header h1 {
        font-size: 2.25rem;
        font-weight: 800;
        color: var(--foreground);
        margin: 0 0 8px 0;
        letter-spacing: -0.5px;
    }
    .privacy-updated {
        color: var(--muted-foreground);
        font-size: 0.9rem;
        margin: 0;
    }
    .privacy-content {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 40px;
        box-shadow: var(--shadow-sm);
        animation: slideUp 0.6s ease-out 0.1s both;
    }
    .privacy-section {
        margin-bottom: 32px;
    }
    .privacy-section:last-child {
        margin-bottom: 0;
    }
    .privacy-section h2 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--foreground);
        margin: 0 0 12px 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .privacy-section h2 i {
        color: var(--primary);
        font-size: 1rem;
    }
    .privacy-section p {
        color: var(--muted-foreground);
        line-height: 1.7;
        font-size: 0.95rem;
        margin: 0;
    }
    .privacy-section ul {
        color: var(--muted-foreground);
        line-height: 1.8;
        font-size: 0.95rem;
        margin: 0;
        padding-left: 1.25rem;
    }
    .privacy-back {
        text-align: center;
        margin-top: 40px;
    }
    .privacy-back .btn-outline-custom {
        padding: 0.75rem 2rem;
        font-size: 0.9rem;
    }
    @@media (max-width: 640px) {
        .privacy-content { padding: 28px 20px; }
        .privacy-header h1 { font-size: 1.75rem; }
    }
</style>
