@{
    ViewData["Title"] = "Creative Collaboration";
}

<canvas id="particleCanvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none;"></canvas>

<div class="hero-section">
    <div class="hero-inner">
        <h1 id="revealTitle" class="hero-title">
            DRAW<br /><span class="hero-title-accent">SYNC</span>
        </h1>
        <p class="hero-tagline">
            The real-time collaborative canvas for modern teams.<br />
            Simple. Fast. Powerful.
        </p>

        <div class="hero-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Organization" asp-action="Index" class="btn-primary-custom hero-cta">
                    <i class="bi bi-grid-1x2 me-2"></i> Go to Workspaces
                </a>
                <a asp-controller="Whiteboard" asp-action="Index" class="btn-outline-custom hero-cta-secondary">
                    <i class="bi bi-easel me-2"></i> Open Whiteboard
                </a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Register" class="btn-primary-custom hero-cta">
                    Try for Free
                </a>
                <a asp-controller="Auth" asp-action="Login" class="btn-outline-custom hero-cta-secondary">
                    Sign In
                </a>
            }
        </div>

        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="feature-row">
                <div class="feature-chip">
                    <i class="bi bi-broadcast-pin"></i>
                    <span>Realtime Sync</span>
                </div>
                <div class="feature-chip">
                    <i class="bi bi-people-fill"></i>
                    <span>Team Workspaces</span>
                </div>
                <div class="feature-chip">
                    <i class="bi bi-map-fill"></i>
                    <span>GIS Maps</span>
                </div>
                <div class="feature-chip">
                    <i class="bi bi-magic"></i>
                    <span>Neon Brush</span>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        body { background-color: var(--background) !important; }

        .hero-section {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: calc(100vh - 70px);
            padding: 40px 20px;
            text-align: center;
        }

        .hero-inner {
            max-width: 760px;
            width: 100%;
        }

        .hero-title {
            font-family: 'Syncopate', sans-serif;
            font-weight: 700;
            font-size: clamp(3rem, 12vw, 7rem);
            line-height: 0.9;
            letter-spacing: -4px;
            margin: 0 0 1.5rem 0;
            color: var(--foreground);
            opacity: 0;
        }

        .hero-title-accent {
            color: var(--primary);
        }

        .reveal-char {
            display: inline-block;
            animation: reveal 0.8s cubic-bezier(0.77, 0, 0.175, 1) forwards;
        }

        .hero-tagline {
            max-width: 520px;
            margin: 0 auto 2.5rem;
            font-size: 1.15rem;
            line-height: 1.6;
            color: var(--muted-foreground);
            opacity: 0;
            animation: fadeIn 1s ease 1s forwards;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            justify-content: center;
            margin-bottom: 3.5rem;
            opacity: 0;
            animation: fadeInUp 1s ease 1.2s forwards;
        }

        .hero-cta,
        .hero-cta-secondary {
            padding: 0.9rem 2.2rem;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
        }

        .feature-row {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            opacity: 0;
            animation: fadeInUp 1s ease 1.5s forwards;
        }

        .feature-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 100px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--muted-foreground);
            box-shadow: var(--shadow-xs);
            transition: all 0.25s ease;
        }

        .feature-chip:hover {
            transform: translateY(-2px);
            border-color: var(--primary);
            color: var(--primary);
            box-shadow: var(--shadow-md);
        }

        .feature-chip i {
            font-size: 0.95rem;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes reveal {
            0% { filter: blur(10px); opacity: 0; transform: scale(0.9); }
            100% { filter: blur(0); opacity: 1; transform: scale(1); }
        }

        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 640px) {
            .hero-actions { flex-direction: column; align-items: stretch; }
            .hero-cta, .hero-cta-secondary { width: 100%; justify-content: center; }
        }
    </style>
    <script>
        // Particle Canvas Logic
        const canvas = document.getElementById('particleCanvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function getParticleColor() {
            const isDark = document.documentElement.classList.contains('dark');
            return isDark ? 'rgba(220, 220, 220, 0.45)' : 'rgba(0, 0, 0, 0.35)';
        }

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 2;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
            draw() {
                ctx.fillStyle = getParticleColor();
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        // --- Futuristic Mouse Trail Logic ---
        let trail = [];
        let trailParticles = [];
        const MAX_TRAIL_AGE = 120;

        let lastMouseTime = 0;
        window.addEventListener('mousemove', (e) => {
            const now = Date.now();
            // Throttle trail emission a touch for performance.
            if (now - lastMouseTime < 8) return;
            lastMouseTime = now;
            trail.push({ x: e.clientX, y: e.clientY, age: 0, timestamp: now });

            if (Math.random() > 0.5) {
                trailParticles.push({
                    x: e.clientX,
                    y: e.clientY,
                    vx: (Math.random() - 0.5) * 2,
                    vy: (Math.random() - 0.5) * 2,
                    size: Math.random() * 3 + 1,
                    life: 1.0
                });
            }
        });

        function drawNeonTrail() {
            if (trail.length < 2) return;

            const isDark = document.documentElement.classList.contains('dark');
            const neonColor = isDark ? '200, 200, 200' : '0, 0, 0';
            const coreColor = isDark ? '255, 255, 255' : '80, 80, 80';

            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';

            for (let i = 1; i < trail.length; i++) {
                const p1 = trail[i - 1];
                const p2 = trail[i];

                const dist = Math.hypot(p2.x - p1.x, p2.y - p1.y);
                if (dist > 150) continue;

                const ageRatio = p2.age / MAX_TRAIL_AGE;
                const alpha = 1 - ageRatio;
                if (alpha <= 0) continue;

                ctx.shadowBlur = 35 * alpha;
                ctx.shadowColor = `rgba(${neonColor}, ${alpha * 0.5})`;
                ctx.lineWidth = 15 * alpha;
                ctx.strokeStyle = `rgba(${neonColor}, ${alpha * 0.1})`;
                ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();

                ctx.shadowBlur = 10 * alpha;
                ctx.lineWidth = 6 * alpha;
                ctx.strokeStyle = `rgba(${neonColor}, ${alpha * 0.7})`;
                ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();

                ctx.shadowBlur = 5 * alpha;
                ctx.shadowColor = '#fff';
                ctx.lineWidth = 2 * alpha;
                ctx.strokeStyle = `rgba(${coreColor}, ${alpha * 0.9})`;
                ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();
            }

            ctx.shadowBlur = 0;

            trailParticles.forEach((p, index) => {
                p.x += p.vx;
                p.y += p.vy;
                p.life -= 0.02;
                if (p.life <= 0) { trailParticles.splice(index, 1); return; }

                ctx.fillStyle = `rgba(${neonColor}, ${p.life * 0.6})`;
                ctx.beginPath(); ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2); ctx.fill();
            });

            trail.forEach(p => p.age++);
            trail = trail.filter(p => p.age < MAX_TRAIL_AGE);
        }

        function initParticles() {
            resize();
            particles = Array.from({ length: 80 }, () => new Particle());
            animate();
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            drawNeonTrail();
            requestAnimationFrame(animate);
        }

        // Title Reveal Logic
        function initReveal() {
            const title = document.getElementById('revealTitle');
            const text = "DRAWSYNC";
            title.innerHTML = '';
            title.style.opacity = '1';

            [...text].forEach((char, i) => {
                const span = document.createElement('span');
                span.textContent = char;
                span.className = 'reveal-char';
                span.style.animationDelay = `${i * 0.1}s`;
                if (i >= 4) span.style.color = 'var(--primary)';
                else span.style.color = 'var(--foreground)';
                if (i === 4) title.appendChild(document.createElement('br'));
                title.appendChild(span);
            });
        }

        // Parallax Effect
        window.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 20;
            const y = (e.clientY / window.innerHeight - 0.5) * 20;
            const title = document.getElementById('revealTitle');
            if (title) {
                title.style.transform = `translate3d(${x}px, ${y}px, 0)`;
            }
        });

        window.addEventListener('resize', resize);
        initParticles();
        setTimeout(initReveal, 500);
    </script>
}
