@{
    ViewData["Title"] = "Creative Collaboration";
}

<canvas id="particleCanvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none;"></canvas>

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="text-center">
        <h1 id="revealTitle" class="display-1 fw-bold mb-6" style="font-family: 'Syncopate', sans-serif; letter-spacing: -4px; line-height: 0.9; opacity: 0; color: var(--foreground);">
            DRAW<br/><span style="color: var(--primary)">SYNC</span>
        </h1>
        <p class="mb-8" style="max-width: 500px; margin: 0 auto; font-size: 1.1rem; line-height: 1.6; animation: fadeIn 1s ease 1s forwards; opacity: 0; color: var(--muted-foreground);">
            The real-time collaborative canvas for modern teams. Simple. Fast. Powerful.
        </p>
        
        <div class="d-flex flex-column gap-3 align-items-center mt-5" style="animation: fadeInUp 1s ease 1.2s forwards; opacity: 0;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Organization" asp-action="Index" class="btn-primary-custom px-5">Dashboard</a>
                
                <div class="mt-4 p-3 border rounded text-start" style="max-width: 600px; width: 100%; font-family: var(--font-mono); font-size: 0.75rem; overflow-x: auto; background: var(--card); color: var(--foreground); border-color: var(--border);">
                    <h6 class="mb-2 fw-bold text-uppercase" style="font-size: 0.7rem; color: var(--muted-foreground);">Appwrite Response Log</h6>
                    <pre class="m-0" style="color: inherit; background: transparent; border: none;">@ViewBag.RawApiResponse</pre>
                </div>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Register" class="btn-primary-custom px-5">Try for Free</a>
                <a asp-controller="Auth" asp-action="Login" class="btn-outline-custom px-5">Sign In</a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <style>
        body { background-color: var(--background) !important; }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes reveal {
            0% { filter: blur(10px); opacity: 0; transform: scale(0.9); }
            100% { filter: blur(0); opacity: 1; transform: scale(1); }
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .reveal-char {
            display: inline-block;
            animation: reveal 0.8s cubic-bezier(0.77, 0, 0.175, 1) forwards;
        }
    </style>
    <script>
        // Particle Canvas Logic
        const canvas = document.getElementById('particleCanvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function getParticleColor() {
            // Read the current --primary color from CSS and use it for particles
            const isDark = document.documentElement.classList.contains('dark');
            return isDark ? 'rgba(180, 60, 60, 0.6)' : 'rgba(100, 30, 30, 0.5)';
        }

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 2;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
            draw() {
                ctx.fillStyle = getParticleColor();
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        // --- Futuristic Mouse Trail Logic ---
        let trail = [];
        let trailParticles = [];
        const MAX_TRAIL_AGE = 120; // Slightly faster fade for "energy" look

        window.addEventListener('mousemove', (e) => {
            const now = Date.now();
            trail.push({ x: e.clientX, y: e.clientY, age: 0, timestamp: now });
            
            // Add a few "energy dust" particles at the cursor
            if (Math.random() > 0.5) {
                trailParticles.push({
                    x: e.clientX,
                    y: e.clientY,
                    vx: (Math.random() - 0.5) * 2,
                    vy: (Math.random() - 0.5) * 2,
                    size: Math.random() * 3 + 1,
                    life: 1.0
                });
            }
        });

        function drawNeonTrail() {
            if (trail.length < 2) return;

            const isDark = document.documentElement.classList.contains('dark');
            
            // Neon Palette (Using theme burgundy as base)
            const neonColor = isDark ? '255, 45, 85' : '180, 20, 60';
            const coreColor = '255, 255, 255';

            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';

            for (let i = 1; i < trail.length; i++) {
                const p1 = trail[i - 1];
                const p2 = trail[i];
                
                const dist = Math.hypot(p2.x - p1.x, p2.y - p1.y);
                if (dist > 150) continue; 

                const ageRatio = p2.age / MAX_TRAIL_AGE;
                const alpha = 1 - ageRatio;
                if (alpha <= 0) continue;

                // 1. Atmospheric Glow (Widest, very soft)
                ctx.shadowBlur = 35 * alpha;
                ctx.shadowColor = `rgba(${neonColor}, ${alpha * 0.5})`;
                ctx.lineWidth = 15 * alpha;
                ctx.strokeStyle = `rgba(${neonColor}, ${alpha * 0.1})`;
                ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();

                // 2. Neon Halo (Medium, intense)
                ctx.shadowBlur = 10 * alpha;
                ctx.lineWidth = 6 * alpha;
                ctx.strokeStyle = `rgba(${neonColor}, ${alpha * 0.7})`;
                ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();

                // 3. Electric Core (Thin, White)
                ctx.shadowBlur = 5 * alpha;
                ctx.shadowColor = '#fff';
                ctx.lineWidth = 2 * alpha;
                ctx.strokeStyle = `rgba(${coreColor}, ${alpha * 0.9})`;
                ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();
            }

            // Reset for performance
            ctx.shadowBlur = 0;

            // Neon Sparks
            trailParticles.forEach((p, index) => {
                p.x += p.vx;
                p.y += p.vy;
                p.life -= 0.02;
                if (p.life <= 0) { trailParticles.splice(index, 1); return; }

                ctx.fillStyle = `rgba(${neonColor}, ${p.life * 0.6})`;
                ctx.beginPath(); ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2); ctx.fill();
            });

            // --- CRITICAL: Update age and filter old points to ensure they disappear ---
            trail.forEach(p => p.age++);
            trail = trail.filter(p => p.age < MAX_TRAIL_AGE);
        }

        function initParticles() {
            resize();
            particles = Array.from({ length: 80 }, () => new Particle());
            animate();
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Draw background particles (fewer and slower for focus on trail)
            particles.forEach(p => {
                p.update();
                p.draw();
            });

            // Draw neon trail
            drawNeonTrail();

            requestAnimationFrame(animate);
        }

        // Title Reveal Logic
        function initReveal() {
            const title = document.getElementById('revealTitle');
            const text = "DRAWSYNC";
            title.innerHTML = '';
            title.style.opacity = '1';

            const style = getComputedStyle(document.documentElement);
            const primaryColor = style.getPropertyValue('--primary').trim();
            const fgColor = style.getPropertyValue('--foreground').trim();

            [...text].forEach((char, i) => {
                const span = document.createElement('span');
                span.textContent = char;
                span.className = 'reveal-char';
                span.style.animationDelay = `${i * 0.1}s`;
                if (i >= 4) span.style.color = 'var(--primary)';
                else span.style.color = 'var(--foreground)';
                if (i === 4) title.appendChild(document.createElement('br'));
                title.appendChild(span);
            });
        }

        // Parallax Effect
        window.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 20;
            const y = (e.clientY / window.innerHeight - 0.5) * 20;
            const title = document.getElementById('revealTitle');
            if (title) {
                title.style.transform = `translate3d(${x}px, ${y}px, 0)`;
            }
        });

        window.addEventListener('resize', resize);
        initParticles();
        setTimeout(initReveal, 500);
    </script>
}
